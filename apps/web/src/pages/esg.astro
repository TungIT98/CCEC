---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatWidget from '../components/chat/ChatWidget.svelte';
import ESGChart from '../components/ESGChart.svelte';
---

<BaseLayout title="ESG Analytics — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-teal-500 to-teal-700 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
          <span class="text-slate-300">/</span>
          <span class="font-semibold text-slate-700 text-sm">ESG Analytics</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="ccec-badge ccec-badge-teal text-xs hidden md:block">Sustainalytics · MSCI · Bloomberg</span>
          <a href="/dashboard" class="px-4 py-1.5 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:border-teal-400 hover:text-teal-700 transition-all">
            Dashboard
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 py-8 space-y-6">

        <!-- PAGE TITLE -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">ESG Analytics</h1>
            <p class="text-sm text-slate-500 mt-0.5">Điểm bền vững · Xếp hạng MSCI · Phân tích ngành</p>
          </div>
          <div class="flex items-center gap-2 ccec-badge ccec-badge-green">
            <span class="status-dot status-dot-live"></span>
            Cập nhật Q4 2025
          </div>
        </div>

        <!-- PORTFOLIO SCORE CARD -->
        <div class="ccec-card p-6">
          <div class="flex flex-col md:flex-row md:items-end gap-6 mb-5">
            <div class="flex items-end gap-4 flex-1">
              <div class="text-6xl font-extrabold text-slate-900 leading-none">77</div>
              <div>
                <div class="text-sm font-semibold text-slate-700">Điểm ESG Danh mục</div>
                <div class="text-xs text-slate-400">6 công ty · Top 32% toàn cầu</div>
              </div>
            </div>
            <div class="flex items-center gap-4 md:ml-auto">
              <div class="text-right">
                <div class="text-xs text-slate-400 mb-0.5">vs 2023</div>
                <div class="text-lg font-bold text-emerald-600">+12 điểm</div>
              </div>
              <div class="text-right">
                <div class="text-xs text-slate-400 mb-0.5">Thay đổi</div>
                <div class="text-lg font-bold text-emerald-600">+18.5%</div>
              </div>
              <!-- MSCI Rating -->
              <div class="flex items-center gap-2 border-l border-slate-200 pl-4">
                <div class="w-9 h-9 rounded-lg bg-emerald-100 flex items-center justify-center">
                  <span class="text-sm font-extrabold text-emerald-700">A</span>
                </div>
                <div>
                  <div class="text-xs font-semibold text-slate-700">MSCI Rating</div>
                  <div class="text-xs text-slate-400">Top 32%</div>
                </div>
              </div>
            </div>
          </div>
          <ESGChart client:load />
        </div>

        <!-- SECTOR BREAKDOWN -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-slate-600">Năng lượng</span>
            </div>
            <div class="text-3xl font-bold text-slate-900 mb-3">71</div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs text-slate-400">Điểm E/S/G</span>
              <span class="text-xs font-semibold text-blue-600">Trung bình</span>
            </div>
            <div class="bg-slate-100 rounded-full h-2 overflow-hidden">
              <div class="h-full rounded-full bg-blue-500" style="width:71%"></div>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-slate-600">Công nghệ</span>
            </div>
            <div class="text-3xl font-bold text-slate-900 mb-3">85</div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs text-slate-400">Điểm E/S/G</span>
              <span class="text-xs font-semibold text-purple-600">Cao nhất</span>
            </div>
            <div class="bg-slate-100 rounded-full h-2 overflow-hidden">
              <div class="h-full rounded-full bg-purple-500" style="width:85%"></div>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-slate-600">Tài chính</span>
            </div>
            <div class="text-3xl font-bold text-slate-900 mb-3">82</div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs text-slate-400">Điểm E/S/G</span>
              <span class="text-xs font-semibold text-teal-600">Tốt</span>
            </div>
            <div class="bg-slate-100 rounded-full h-2 overflow-hidden">
              <div class="h-full rounded-full bg-teal-600" style="width:82%"></div>
            </div>
          </div>
        </div>

        <!-- MSCI RATING JOURNEY -->
        <div class="ccec-card p-6">
          <div class="flex items-center justify-between mb-5">
            <div>
              <h3 class="font-semibold text-slate-800">Hành trình xếp hạng MSCI</h3>
              <p class="text-xs text-slate-400 mt-0.5">Tiến bộ từ CCC → A trong 3 năm</p>
            </div>
            <div class="ccec-badge ccec-badge-green text-xs">Current: A</div>
          </div>
          <div class="flex items-center gap-3 overflow-x-auto py-2">
            {[
              { label: 'CCC', active: false }, { label: 'B', active: false },
              { label: 'BB', active: false }, { label: 'BBB', active: false },
              { label: 'A', active: true }, { label: 'AA', active: false }, { label: 'AAA', active: false },
            ].map(r => (
              <div class={`flex flex-col items-center gap-1.5 flex-shrink-0`}>
                <div class={`w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold transition-all
                  ${r.active
                    ? 'bg-emerald-500 text-white shadow-md'
                    : 'bg-slate-100 text-slate-400'}`}>
                  {r.label}
                </div>
                <div class={`text-xs font-medium ${r.active ? 'text-emerald-600' : 'text-slate-400'}`}>{r.label}</div>
              </div>
            ))}
          </div>
          <div class="mt-4 grid grid-cols-3 gap-4 pt-4 border-t border-slate-100">
            <div class="text-center">
              <div class="text-xl font-bold text-slate-700">2022</div>
              <div class="text-xs text-slate-400">Khởi đầu CCC</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-teal-600">2024</div>
              <div class="text-xs text-slate-400">Đạt xếp hạng A</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-slate-700">2025+</div>
              <div class="text-xs text-slate-400">Mục tiêu AA</div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>