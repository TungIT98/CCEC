---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Renewable Energy — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
          <span class="text-slate-300">/</span>
          <span class="font-semibold text-slate-700 text-sm">Năng lượng tái tạo</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs text-slate-400 hidden md:block">IRENA · IEA · GEM · Global Energy Monitor</span>
          <a href="/dashboard" class="px-4 py-1.5 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:border-blue-400 hover:text-blue-700 transition-all">
            Dashboard
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 py-8 space-y-6">

        <!-- PAGE TITLE -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Renewable Energy Tracker</h1>
            <p class="text-sm text-slate-500 mt-0.5">Global capacity · Generation trends · Vietnam energy transition</p>
          </div>
          <div class="ccec-badge ccec-badge-blue text-xs">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/></svg>
            IRENA Data
          </div>
        </div>

        <!-- STATS BAR -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Global Solar</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">1,627 <span class="text-sm font-normal text-slate-400">GW</span></div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-3 h-3 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
              <span class="text-xs text-emerald-500 font-semibold">+32% YoY</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-sky-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Global Wind</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">1,021 <span class="text-sm font-normal text-slate-400">GW</span></div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-3 h-3 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
              <span class="text-xs text-emerald-500 font-semibold">+17% YoY</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Vietnam RE Target</span>
            </div>
            <div class="text-2xl font-bold text-emerald-600">~30%</div>
            <div class="flex items-center gap-1 mt-2">
              <span class="text-xs text-slate-400">2030 NDC goal</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Installed Capacity</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">76.7 <span class="text-sm font-normal text-slate-400">GW total</span></div>
            <div class="flex items-center gap-1 mt-2">
              <span class="text-xs text-slate-400">Solar + Wind + Hydro</span>
            </div>
          </div>
        </div>

        <!-- CAPACITY CHART + TRENDS -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="ccec-card p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="font-semibold text-slate-800">Capacity by Energy Type</h3>
                <p class="text-xs text-slate-400 mt-0.5">Global installed capacity (GW) · IRENA 2024</p>
              </div>
            </div>
            <div id="capacity-chart" class="w-full" style="height: 260px;"></div>
          </div>

          <div class="ccec-card p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="font-semibold text-slate-800">Generation Trends</h3>
                <p class="text-xs text-slate-400 mt-0.5">Yearly generation (GWh) · 2019–2024</p>
              </div>
            </div>
            <div id="trends-chart" class="w-full" style="height: 260px;"></div>
          </div>
        </div>

        <!-- COUNTRY COMPARISON TABLE -->
        <div class="ccec-card overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100">
            <h3 class="font-semibold text-slate-800">Renewable Energy by Country</h3>
            <p class="text-xs text-slate-400 mt-0.5">Installed capacity (MW) · Top 10 countries</p>
          </div>
          <div class="overflow-x-auto">
            <table class="ccec-table">
              <thead>
                <tr>
                  <th class="text-left">Country</th>
                  <th class="text-right">Solar (MW)</th>
                  <th class="text-right">Wind (MW)</th>
                  <th class="text-right">Hydro (MW)</th>
                  <th class="text-right">Total (MW)</th>
                  <th class="text-right">2024 Gen (GWh)</th>
                  <th class="text-center">RE Share</th>
                </tr>
              </thead>
              <tbody id="country-tbody">
                <tr><td colspan="7" class="text-center py-8 text-slate-400 text-sm">Loading data...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- RENEWABLE MAP PLACEHOLDER -->
        <div class="ccec-card p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-slate-800">Renewable Energy Infrastructure</h3>
              <p class="text-xs text-slate-400 mt-0.5">Solar farms · Wind parks · Hydro plants (GEM data)</p>
            </div>
          </div>
          <div id="energy-map" class="w-full rounded-xl overflow-hidden" style="height: 380px; background: #f0f9ff; display: flex; align-items: center; justify-content: center;">
            <div class="text-center text-slate-400">
              <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <p class="text-sm">Map integration pending<br/><span class="text-xs">Use Leaflet + OpenStreetMap (see MAR-848)</span></p>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>

<script>
import * as echarts from 'echarts';

const API_BASE = (import.meta as any).env?.PUBLIC_API_URL || 'http://localhost:8000';

function getToken() {
  try {
    const raw = localStorage.getItem('ccec_tokens');
    if (raw) return JSON.parse(raw).access_token;
  } catch {}
  return '';
}

// Capacity bar chart
const capDom = document.getElementById('capacity-chart')!;
const capChart = echarts.init(capDom);

const energyTypes = ['Solar', 'Wind', 'Hydro', 'Geothermal', 'Biomass'];
const capacities = [1627, 1021, 1390, 16.5, 87];
const capColors = ['#f59e0b', '#0ea5e9', '#3b82f6', '#f97316', '#22c55e'];

capChart.setOption({
  backgroundColor: 'transparent',
  tooltip: { trigger: 'axis', formatter: (p: any) => `${p[0].name}: <b>${p[0].value.toLocaleString()} GW</b>` },
  grid: { left: 60, right: 20, top: 10, bottom: 30 },
  xAxis: { type: 'category', data: energyTypes, axisLine: { lineStyle: { color: '#e2e8f0' } }, axisLabel: { color: '#94a3b8', fontSize: 11 } },
  yAxis: { type: 'value', axisLine: { show: false }, splitLine: { lineStyle: { color: '#f1f5f9' } }, axisLabel: { color: '#94a3b8', fontSize: 11, formatter: (v: number) => v >= 1000 ? `${(v/1000).toFixed(1)}k` : v.toString() } },
  series: [{
    type: 'bar',
    data: capacities.map((v, i) => ({ value: v, itemStyle: { color: capColors[i], borderRadius: [4, 4, 0, 0] } })),
    barWidth: '50%',
    emphasis: { itemStyle: { shadowBlur: 10, shadowColor: 'rgba(0,0,0,0.2)' } },
  }],
});

window.addEventListener('resize', () => { capChart.resize(); trendsChart.resize(); });

// Trends line chart
const trendsDom = document.getElementById('trends-chart')!;
const trendsChart = echarts.init(trendsDom);

const years = ['2019', '2020', '2021', '2022', '2023', '2024'];
const solarTrend = [629, 756, 942, 1185, 1419, 1627];
const windTrend  = [623, 743, 849, 899, 963, 1021];
const hydroTrend = [1290, 1310, 1330, 1355, 1375, 1390];

trendsChart.setOption({
  backgroundColor: 'transparent',
  tooltip: { trigger: 'axis', formatter: (p: any) => p[0].axisValue + '<br/>' + p.map((x: any) => `<span style="color:${x.color}">●</span> ${x.seriesName}: <b>${x.value.toLocaleString()} GW</b>`).join('<br/>') },
  legend: { top: 0, right: 10, textStyle: { color: '#94a3b8', fontSize: 11 } },
  grid: { left: 60, right: 20, top: 30, bottom: 30 },
  xAxis: { type: 'category', data: years, axisLine: { lineStyle: { color: '#e2e8f0' } }, axisLabel: { color: '#94a3b8', fontSize: 11 } },
  yAxis: { type: 'value', axisLine: { show: false }, splitLine: { lineStyle: { color: '#f1f5f9' } }, axisLabel: { color: '#94a3b8', fontSize: 11, formatter: (v: number) => `${(v/1000).toFixed(1)}k` } },
  series: [
    { name: 'Solar', type: 'line', data: solarTrend, smooth: true, lineStyle: { width: 2, color: '#f59e0b' }, symbol: 'circle', symbolSize: 4, itemStyle: { color: '#f59e0b' } },
    { name: 'Wind',  type: 'line', data: windTrend,  smooth: true, lineStyle: { width: 2, color: '#0ea5e9' }, symbol: 'circle', symbolSize: 4, itemStyle: { color: '#0ea5e9' } },
    { name: 'Hydro', type: 'line', data: hydroTrend, smooth: true, lineStyle: { width: 2, color: '#3b82f6' }, symbol: 'circle', symbolSize: 4, itemStyle: { color: '#3b82f6' } },
  ],
});

// Country table
async function loadCountryData() {
  const tbody = document.getElementById('country-tbody')!;
  try {
    const res = await fetch(`${API_BASE}/api/v1/energy/country/VNM`, {
      headers: { Authorization: `Bearer ${getToken()}` },
    });
    if (!res.ok) throw new Error('API offline');
    const data: any = await res.json();
    tbody.innerHTML = `
      <tr>
        <td class="font-medium text-slate-800 text-sm">${data.country_name || 'Vietnam'}</td>
        <td class="text-right font-semibold text-slate-700 text-sm">${((data.by_energy_type?.['Solar'] || 0) / 1000).toFixed(1)}k</td>
        <td class="text-right font-semibold text-slate-700 text-sm">${((data.by_energy_type?.['Wind'] || 0) / 1000).toFixed(1)}k</td>
        <td class="text-right font-semibold text-slate-700 text-sm">${((data.by_energy_type?.['Hydro'] || 0) / 1000).toFixed(1)}k</td>
        <td class="text-right font-bold text-blue-700 text-sm">${(data.total_capacity_mw / 1000).toFixed(1)}k MW</td>
        <td class="text-right text-slate-600 text-sm">—</td>
        <td class="text-center"><span class="ccec-badge ccec-badge-blue text-xs">~30%</span></td>
      </tr>
    `;
  } catch {
    // Sample data
    const countries = [
      { name: 'China', solar: 611.5, wind: 441.3, hydro: 356.4, total: 1409.2, gen: 2890.7 },
      { name: 'United States', solar: 162.3, wind: 146.8, hydro: 79.9, total: 389.0, gen: 820.1 },
      { name: 'India', solar: 81.8, wind: 44.9, hydro: 51.7, total: 178.4, gen: 390.2 },
      { name: 'EU', solar: 313.2, wind: 260.5, hydro: 149.2, total: 722.9, gen: 1305.6 },
      { name: 'Vietnam', solar: 18.7, wind: 12.4, hydro: 27.2, total: 58.3, gen: 89.5 },
      { name: 'Brazil', solar: 37.2, wind: 28.9, hydro: 109.3, total: 175.4, gen: 482.8 },
      { name: 'Australia', solar: 42.1, wind: 24.8, hydro: 7.4, total: 74.3, gen: 142.7 },
      { name: 'Japan', solar: 82.4, wind: 4.8, hydro: 22.0, total: 109.2, gen: 189.3 },
    ];
    tbody.innerHTML = countries.map(c => `
      <tr class="hover:bg-blue-50/50 transition-colors">
        <td class="font-medium text-slate-800 text-sm">${c.name}</td>
        <td class="text-right font-semibold text-amber-600 text-sm">${c.solar.toFixed(1)}k</td>
        <td class="text-right font-semibold text-sky-600 text-sm">${c.wind.toFixed(1)}k</td>
        <td class="text-right font-semibold text-blue-600 text-sm">${c.hydro.toFixed(1)}k</td>
        <td class="text-right font-bold text-blue-800 text-sm">${c.total.toFixed(1)}k MW</td>
        <td class="text-right text-slate-600 text-sm">${c.gen.toFixed(1)}k</td>
        <td class="text-center"><span class="ccec-badge ccec-badge-green text-xs">${((c.total / 1409.2) * 100).toFixed(0)}%</span></td>
      </tr>
    `).join('');
  }
}

loadCountryData();
</script>