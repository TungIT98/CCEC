---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Climate Forecast — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
        </div>
        <nav class="flex items-center gap-4 text-sm font-medium text-slate-600">
          <a href="/dashboard" class="hover:text-amber-600 transition-colors">Dashboard</a>
          <a href="/emissions" class="hover:text-amber-600 transition-colors">Emissions</a>
          <a href="/esg" class="hover:text-amber-600 transition-colors">ESG</a>
          <a href="/carbon-credits" class="hover:text-amber-600 transition-colors">Carbon</a>
          <a href="/energy" class="hover:text-amber-600 transition-colors">Energy</a>
          <a href="/policies" class="hover:text-amber-600 transition-colors">Policies</a>
          <a href="/api-docs" class="hover:text-amber-600 transition-colors">API</a>
        </nav>
      </div>
    </header>

    <!-- HERO -->
    <section class="bg-gradient-to-br from-slate-50 via-amber-50 to-amber-100 border-b border-amber-200/50">
      <div class="max-w-7xl mx-auto px-6 py-12 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 text-amber-700 text-xs font-semibold mb-4 border border-amber-300/50">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4"/></svg>
          Prophet Forecasting
        </div>
        <h1 class="text-4xl font-bold text-slate-900 mb-3">Climate Data Forecasts</h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          AI-powered time-series forecasting for emissions, carbon prices, and temperature — powered by Prophet.
        </p>
      </div>
    </section>

    <!-- MAIN CONTENT -->
    <main class="flex-1 max-w-7xl mx-auto px-6 py-10 w-full">

      <!-- FORECAST CARDS -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

        <!-- Emissions Forecast Card -->
        <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
          <div class="bg-gradient-to-br from-emerald-500 to-emerald-700 px-5 py-4">
            <div class="flex items-center gap-2 text-white mb-1">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="font-semibold text-sm">CO₂ Emissions</span>
            </div>
            <p class="text-emerald-100 text-xs">Vietnam — Prophet forecast</p>
          </div>
          <div class="p-5">
            <div class="text-2xl font-bold text-slate-900 mb-1" id="emissions-value">—</div>
            <div class="text-sm text-slate-500 mb-4">kt CO₂e (monthly avg)</div>
            <button
              onclick="runEmissionsForecast()"
              class="w-full px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-sm font-semibold transition-colors">
              Run Forecast
            </button>
            <div class="mt-3 text-xs text-slate-400">Data: 2020–2026 training window</div>
          </div>
        </div>

        <!-- Carbon Price Forecast Card -->
        <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
          <div class="bg-gradient-to-br from-amber-400 to-amber-600 px-5 py-4">
            <div class="flex items-center gap-2 text-white mb-1">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="font-semibold text-sm">Carbon Price</span>
            </div>
            <p class="text-amber-100 text-xs">VER/CER/Gold Standard</p>
          </div>
          <div class="p-5">
            <div class="text-2xl font-bold text-slate-900 mb-1" id="carbon-price-value">—</div>
            <div class="text-sm text-slate-500 mb-4">USD / tCO₂e</div>
            <button
              onclick="runCarbonPriceForecast()"
              class="w-full px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded-xl text-sm font-semibold transition-colors">
              Run Forecast
            </button>
            <div class="mt-3 text-xs text-slate-400">Historical: 2020–2026</div>
          </div>
        </div>

        <!-- Temperature Forecast Card -->
        <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
          <div class="bg-gradient-to-br from-sky-500 to-sky-700 px-5 py-4">
            <div class="flex items-center gap-2 text-white mb-1">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
              <span class="font-semibold text-sm">Temperature</span>
            </div>
            <p class="text-sky-100 text-xs">Hanoi station</p>
          </div>
          <div class="p-5">
            <div class="text-2xl font-bold text-slate-900 mb-1" id="temp-value">—</div>
            <div class="text-sm text-slate-500 mb-4">°C (monthly avg)</div>
            <button
              onclick="runTempForecast()"
              class="w-full px-4 py-2 bg-sky-600 hover:bg-sky-700 text-white rounded-xl text-sm font-semibold transition-colors">
              Run Forecast
            </button>
            <div class="mt-3 text-xs text-slate-400">Seasonal: sinusoidal model</div>
          </div>
        </div>
      </div>

      <!-- FORECAST RESULTS TABLE -->
      <div class="bg-white rounded-2xl border border-slate-200/80 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
          <h2 class="text-lg font-semibold text-slate-900">Forecast Results</h2>
          <p class="text-sm text-slate-500">Prophet time-series — monthly predictions</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 border-b border-slate-100">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Date</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Type</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Forecast</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Lower</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Upper</th>
              </tr>
            </thead>
            <tbody id="forecast-results" class="divide-y divide-slate-100">
              <tr>
                <td colspan="5" class="px-6 py-8 text-center text-slate-400 text-sm">
                  Run a forecast above to see results
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </main>

  </div>
</BaseLayout>

<script>
  const API_BASE = (import.meta as any).env.PUBLIC_API_URL ?? 'http://localhost:8000';

  function authHeaders() {
    try {
      const raw = localStorage.getItem('ccec_tokens');
      if (raw) return { Authorization: `Bearer ${JSON.parse(raw).access_token}` };
    } catch {}
    return {};
  }

  async function apiFetch(path, opts = {}) {
    const res = await fetch(API_BASE + path, {
      ...opts,
      headers: { 'Content-Type': 'application/json', ...authHeaders(), ...(opts.headers || {}) },
    });
    if (!res.ok) throw new Error(`API error: ${res.status}`);
    return res.json();
  }

  async function runEmissionsForecast() {
    try {
      const data = await apiFetch('/api/v1/ai/forecast/emissions', {
        method: 'POST',
        body: JSON.stringify({ country_code: 'VNM', horizon_days: 365 }),
      });
      document.getElementById('emissions-value').textContent = '~' +
        Math.round(data.data[0]?.emissions_kt ?? 0).toLocaleString();
      renderForecastTable(data.data, 'emissions', 'emissions_kt');
    } catch (e) {
      alert('Forecast failed: ' + e.message);
    }
  }

  async function runCarbonPriceForecast() {
    try {
      const data = await apiFetch('/api/v1/ai/forecast/carbon-price', {
        method: 'POST',
        body: JSON.stringify({ standard_type: 'VER', horizon_days: 90 }),
      });
      document.getElementById('carbon-price-value').textContent = '$' +
        (data.data[0]?.price_usd_tCO2e ?? 0).toFixed(2);
      renderForecastTable(data.data, 'carbon-price', 'price_usd_tCO2e');
    } catch (e) {
      alert('Forecast failed: ' + e.message);
    }
  }

  async function runTempForecast() {
    try {
      const data = await apiFetch('/api/v1/ai/forecast/temperature', {
        method: 'POST',
        body: JSON.stringify({ station_id: 'Hanoi', horizon_days: 365 }),
      });
      document.getElementById('temp-value').textContent =
        (data.data[0]?.temp_celsius ?? 0).toFixed(1) + '°C';
      renderForecastTable(data.data, 'temperature', 'temp_celsius');
    } catch (e) {
      alert('Forecast failed: ' + e.message);
    }
  }

  function renderForecastTable(rows, type, valueKey) {
    const tbody = document.getElementById('forecast-results');
    if (!tbody || !rows?.length) return;
    tbody.innerHTML = rows.slice(0, 24).map((r) => {
      const date = new Date(r.ds).toLocaleDateString('vi-VN', { year: 'numeric', month: 'short' });
      const val = (r[valueKey] ?? 0).toFixed(type === 'emissions' ? 0 : 2);
      const low = (r.lower ?? 0).toFixed(type === 'emissions' ? 0 : 2);
      const high = (r.upper ?? 0).toFixed(type === 'emissions' ? 0 : 2);
      const unit = type === 'emissions' ? ' kt CO₂e' : type === 'carbon-price' ? ' USD/tCO₂e' : ' °C';
      return `<tr class="hover:bg-slate-50">
        <td class="px-6 py-3 text-slate-700">${date}</td>
        <td class="px-6 py-3"><span class="px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">${type}</span></td>
        <td class="px-6 py-3 font-semibold text-slate-900">${val}${unit}</td>
        <td class="px-6 py-3 text-slate-500">${low}${unit}</td>
        <td class="px-6 py-3 text-slate-500">${high}${unit}</td>
      </tr>`;
    }).join('');
  }
</script>
