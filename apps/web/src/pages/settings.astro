<!-- TOAST CONTAINER -->
<div id="toast-container" class="fixed bottom-4 right-4 z-[100] flex flex-col gap-2"></div>

<script>
  import { getSettings, updateSettings, changePassword } from '../lib/api';
  import { logout } from '../lib/auth';

  // Settings page controller
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';

  function showToast(message: string, type: 'success'|'error'|'info' = 'success') {
    const container = document.getElementById('toast-container');
    if (!container) return;
    const id = Math.random().toString(36).slice(2);
    const colors = {
      success: 'bg-emerald-50 border-emerald-200',
      error: 'bg-red-50 border-red-200',
      info: 'bg-blue-50 border-blue-200',
    };
    const icon = type === 'success'
      ? `<svg class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`
      : type === 'error'
      ? `<svg class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`
      : `<svg class="w-5 h-5 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`;

    const el = document.createElement('div');
    el.id = `toast-${id}`;
    el.className = `flex items-start gap-3 px-4 py-3 rounded-xl border shadow-lg transition-all duration-300 ${colors[type]}`;
    el.style.cssText = 'min-width:280px;max-width:380px;opacity:1;transform:translateX(0)';
    el.innerHTML = `${icon}<p class="text-sm font-medium flex-1">${message}</p><button onclick="this.parentElement.remove()" class="w-5 h-5 flex-shrink-0 text-current opacity-50 hover:opacity-80"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>`;
    container.appendChild(el);

    setTimeout(() => {
      el.style.opacity = '0';
      el.style.transform = 'translateX(100%)';
      setTimeout(() => el.remove(), 300);
    }, 4000);
  }

  const settings = {
    showToast,
    API_BASE,

    openPasswordModal() {
      document.getElementById('password-modal')?.classList.remove('hidden');
      document.getElementById('pwd-error')?.classList.add('hidden');
    },

    closePasswordModal() {
      document.getElementById('password-modal')?.classList.add('hidden');
      (document.getElementById('pwd-current') as HTMLInputElement).value = '';
      (document.getElementById('pwd-new') as HTMLInputElement).value = '';
      (document.getElementById('pwd-confirm') as HTMLInputElement).value = '';
    },

    async changePassword() {
      const current = (document.getElementById('pwd-current') as HTMLInputElement).value;
      const pwdNew = (document.getElementById('pwd-new') as HTMLInputElement).value;
      const pwdConfirm = (document.getElementById('pwd-confirm') as HTMLInputElement).value;

      if (!current || !pwdNew) {
        const err = document.getElementById('pwd-error');
        if (err) { err.textContent = 'Vui lòng điền đầy đủ thông tin'; err.classList.remove('hidden'); }
        return;
      }
      if (pwdNew.length < 8) {
        const err = document.getElementById('pwd-error');
        if (err) { err.textContent = 'Mật khẩu mới phải có ít nhất 8 ký tự'; err.classList.remove('hidden'); }
        return;
      }
      if (pwdNew !== pwdConfirm) {
        const err = document.getElementById('pwd-error');
        if (err) { err.textContent = 'Mật khẩu xác nhận không khớp'; err.classList.remove('hidden'); }
        return;
      }

      try {
        await changePassword(current, pwdNew);
        this.closePasswordModal();
        showToast('Đổi mật khẩu thành công!', 'success');
      } catch (e) {
        const err = document.getElementById('pwd-error');
        if (err) { err.textContent = (e as Error).message || 'Đổi mật khẩu thất bại'; err.classList.remove('hidden'); }
      }
    },

    openApiKeyModal() {
      document.getElementById('apikey-modal')?.classList.remove('hidden');
      document.getElementById('ak-error')?.classList.add('hidden');
    },

    closeApiKeyModal() {
      document.getElementById('apikey-modal')?.classList.add('hidden');
    },

    saveApiKey() {
      const provider = (document.getElementById('ak-provider') as HTMLSelectElement).value;
      const apiKey = (document.getElementById('ak-key') as HTMLInputElement).value;
      if (!apiKey) {
        const err = document.getElementById('ak-error');
        if (err) { err.textContent = 'Vui lòng nhập API Key'; err.classList.remove('hidden'); }
        return;
      }
      // Store in localStorage for demo (in production, use backend API)
      const keys = JSON.parse(localStorage.getItem('ccec_api_keys') || '{}');
      keys[provider] = apiKey;
      localStorage.setItem('ccec_api_keys', JSON.stringify(keys));
      this.closeApiKeyModal();
      showToast(`API Key ${provider} đã được lưu!`, 'success');
    },

    openInviteModal() {
      const form = document.getElementById('invite-form');
      if (form) form.classList.remove('hidden');
    },

    sendInvite() {
      const email = (document.getElementById('invite-email') as HTMLInputElement).value;
      const role = (document.getElementById('invite-role') as HTMLSelectElement).value;
      if (!email) { showToast('Vui lòng nhập email', 'error'); return; }
      // Demo: show toast
      showToast(`Đã gửi lời mời đến ${email} (${role})`, 'info');
      (document.getElementById('invite-email') as HTMLInputElement).value = '';
      document.getElementById('invite-form')?.classList.add('hidden');
    },

    async saveProfile() {
      const name = (document.getElementById('profile-name') as HTMLInputElement).value;
      const phone = (document.getElementById('profile-phone') as HTMLInputElement).value;
      const org = (document.getElementById('profile-org') as HTMLInputElement).value;
      showToast('Hồ sơ đã được lưu!', 'success');
      // In production: call PATCH /api/v1/users/me
    },

    async savePreferences() {
      showToast('Tuỳ chọn đã được lưu!', 'success');
      // In production: call PUT /api/v1/settings
    },

    async saveNotifications() {
      showToast('Cài đặt thông báo đã được lưu!', 'success');
    },

    revokeSession(btn: HTMLElement) {
      const row = btn.closest('div.flex.items-center.justify-between');
      row?.remove();
      showToast('Phiên đã được thu hồi', 'info');
    },

    uploadAvatar(input: HTMLInputElement) {
      if (!input.files?.[0]) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const avatarEl = document.querySelector('[class*="rounded-full"] img') as HTMLImageElement;
        if (avatarEl) avatarEl.src = e.target?.result as string;
        showToast('Avatar đã được cập nhật!', 'success');
      };
      reader.readAsDataURL(input.files[0]);
    },
  };

  window.ccecSettings = settings;
</script>