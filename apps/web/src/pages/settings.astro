---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tabs from '../components/ui/Tabs.svelte';
import Toggle from '../components/ui/Toggle.svelte';
import Modal from '../components/ui/Modal.svelte';
import Input from '../components/ui/Input.svelte';
import Avatar from '../components/ui/Avatar.svelte';

const tabs = [
  { id: 'profile', label: 'Hồ sơ', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>` },
  { id: 'preferences', label: 'Tuỳ chọn', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>` },
  { id: 'notifications', label: 'Thông báo', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>` },
  { id: 'security', label: 'Bảo mật', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>` },
  { id: 'apikeys', label: 'API Keys', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>` },
  { id: 'team', label: 'Nhóm', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
];
---

<BaseLayout title="Cài đặt — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-amber-500 to-amber-600 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
          <span class="text-slate-300">/</span>
          <span class="font-semibold text-slate-700 text-sm">Cài đặt</span>
        </div>
        <div class="flex items-center gap-3">
          <a href="/dashboard" class="text-sm text-slate-500 hover:text-amber-600 transition font-medium">← Quay lại</a>
        </div>
      </div>
    </header>

    <main class="flex-1 bg-slate-50">
      <div class="max-w-5xl mx-auto px-6 py-8">

        <!-- Page header -->
        <div class="mb-6">
          <h1 class="text-2xl font-bold text-slate-900">Cài đặt</h1>
          <p class="text-sm text-slate-500 mt-1">Quản lý tài khoản, tuỳ chọn và bảo mật</p>
        </div>

        <!-- Tabs -->
        <div class="ccec-card overflow-hidden">
          <Tabs
            client:load
            tabs={tabs}
            onchange={(id) => {
              // show tab panel
              document.querySelectorAll('[id^="tab-panel-"]').forEach(el => {
                (el as HTMLElement).style.display = 'none';
              });
              const panel = document.getElementById(`tab-panel-${id}`);
              if (panel) panel.style.display = 'block';
            }}
          />

          <!-- ================================================
               TAB 1: PROFILE
               ================================================ -->
          <div id="tab-panel-profile" style="display:block">
            <div class="p-6 space-y-6">
              <div>
                <h2 class="text-base font-semibold text-slate-800 mb-4">Hồ sơ cá nhân</h2>

                <!-- Avatar section -->
                <div class="flex items-center gap-5 p-5 bg-slate-50 rounded-xl mb-5">
                  <Avatar client:load name="Người dùng" size="xl" />
                  <div>
                    <p class="text-sm font-semibold text-slate-800">Avatar</p>
                    <p class="text-xs text-slate-500 mb-2">Ảnh hồ sơ sẽ hiển thị trên tất cả các trang</p>
                    <label class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-medium text-slate-600 hover:bg-slate-50 hover:border-teal-400 cursor-pointer transition">
                      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                      Đổi ảnh
                      <input type="file" accept="image/*" class="hidden" onchange="window.ccecSettings?.uploadAvatar(this)" />
                    </label>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Họ và tên</label>
                    <input id="profile-name" type="text" value="Nguyễn Văn Minh"
                      class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none transition" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
                    <input id="profile-email" type="email" value="minh.nguyen@ccec.vn"
                      class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none transition disabled:opacity-60" disabled />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Số điện thoại</label>
                    <input id="profile-phone" type="tel" placeholder="+84 ..."
                      class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none transition" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Tổ chức</label>
                    <input id="profile-org" type="text" value="CCEC Vietnam"
                      class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none transition" />
                  </div>
                </div>

                <div class="mt-5 flex justify-end">
                  <button onclick="window.ccecSettings?.saveProfile()"
                    class="px-5 py-2.5 bg-[#00E5A0] text-[#0B0F1A] font-semibold text-sm rounded-xl hover:bg-[#00C485] transition shadow-sm">
                    Lưu thay đổi
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- ================================================
               TAB 2: PREFERENCES
               ================================================ -->
          <div id="tab-panel-preferences" style="display:none">
            <div class="p-6 space-y-6">
              <h2 class="text-base font-semibold text-slate-800 mb-4">Tuỳ chọn hiển thị</h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-1.5">Ngôn ngữ</label>
                  <select id="pref-lang" class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none">
                    <option value="vi">Tiếng Việt</option>
                    <option value="en">English</option>
                    <option value="fr">Français</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-1.5">Múi giờ</label>
                  <select id="pref-tz" class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none">
                    <option value="Asia/Ho_Chi_Minh">Asia/Ho_Chi_Minh (UTC+7)</option>
                    <option value="Asia/Bangkok">Asia/Bangkok (UTC+7)</option>
                    <option value="Asia/Tokyo">Asia/Tokyo (UTC+9)</option>
                    <option value="UTC">UTC</option>
                    <option value="Europe/London">Europe/London (UTC+0)</option>
                    <option value="America/New_York">America/New_York (UTC-5)</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-1.5">Giao diện</label>
                  <select id="pref-theme" class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none">
                    <option value="dark">Tối (Dark)</option>
                    <option value="light">Sáng (Light)</option>
                    <option value="system">Hệ thống (System)</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-1.5">Định dạng ngày</label>
                  <select id="pref-date-format" class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none">
                    <option value="DD/MM/YYYY">DD/MM/YYYY (31/12/2024)</option>
                    <option value="MM/DD/YYYY">MM/DD/YYYY (12/31/2024)</option>
                    <option value="YYYY-MM-DD">YYYY-MM-DD (2024-12-31)</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-1.5">Số thập phân</label>
                  <select id="pref-decimals" class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 bg-white text-sm focus:border-[#00E5A0] focus:ring-2 focus:ring-[#00E5A0]/20 outline-none">
                    <option value="1">1 chữ số (28.5°C)</option>
                    <option value="2">2 chữ số (28.52°C)</option>
                    <option value="0">Số nguyên (29°C)</option>
                  </select>
                </div>
              </div>

              <div class="flex justify-end">
                <button onclick="window.ccecSettings?.savePreferences()"
                  class="px-5 py-2.5 bg-[#00E5A0] text-[#0B0F1A] font-semibold text-sm rounded-xl hover:bg-[#00C485] transition shadow-sm">
                  Lưu tuỳ chọn
                </button>
              </div>
            </div>
          </div>

          <!-- ================================================
               TAB 3: NOTIFICATIONS
               ================================================ -->
          <div id="tab-panel-notifications" style="display:none">
            <div class="p-6 space-y-6">
              <h2 class="text-base font-semibold text-slate-800 mb-4">Cài đặt thông báo</h2>

              <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl">
                  <div>
                    <p class="text-sm font-medium text-slate-700">Thông báo qua Email</p>
                    <p class="text-xs text-slate-500">Nhận cảnh báo và báo cáo qua email</p>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="notif-email" class="sr-only peer" checked />
                    <div class="w-11 h-6 bg-slate-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-5 peer-checked:bg-[#00E5A0] peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                  </label>
                </div>

                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl">
                  <div>
                    <p class="text-sm font-medium text-slate-700">Thông báo ứng dụng</p>
                    <p class="text-xs text-slate-500">Popup và badge trên trình duyệt</p>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="notif-app" class="sr-only peer" checked />
                    <div class="w-11 h-6 bg-slate-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-5 peer-checked:bg-[#00E5A0] peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                  </label>
                </div>

                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl">
                  <div>
                    <p class="text-sm font-medium text-slate-700">Bản tin hàng tuần</p>
                    <p class="text-xs text-slate-500">Tóm tắt khí hậu và dữ liệu tuần này</p>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="notif-digest" class="sr-only peer" />
                    <div class="w-11 h-6 bg-slate-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-5 peer-checked:bg-[#00E5A0] peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                  </label>
                </div>

                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl">
                  <div>
                    <p class="text-sm font-medium text-slate-700">Cảnh báo thời tiết cực đoan</p>
                    <p class="text-xs text-slate-500">Thông báo ngay khi có bão, lũ lụt, nắng nóng</p>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="notif-extreme" class="sr-only peer" checked />
                    <div class="w-11 h-6 bg-slate-300 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-5 peer-checked:bg-[#00E5A0] peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                  </label>
                </div>
              </div>

              <div class="flex justify-end">
                <button onclick="window.ccecSettings?.saveNotifications()"
                  class="px-5 py-2.5 bg-[#00E5A0] text-[#0B0F1A] font-semibold text-sm rounded-xl hover:bg-[#00C485] transition shadow-sm">
                  Lưu thông báo
                </button>
              </div>
            </div>
          </div>

          <!-- ================================================
               TAB 4: SECURITY
               ================================================ -->
          <div id="tab-panel-security" style="display:none">
            <div class="p-6 space-y-6">
              <h2 class="text-base font-semibold text-slate-800 mb-4">Bảo mật tài khoản</h2>

              <!-- Change password -->
              <div class="p-5 bg-slate-50 rounded-xl space-y-4">
                <div class="flex items-center justify-between mb-1">
                  <div>
                    <p class="text-sm font-semibold text-slate-700">Đổi mật khẩu</p>
                    <p class="text-xs text-slate-500">Cập nhật mật khẩu để bảo vệ tài khoản</p>
                  </div>
                  <button onclick="window.ccecSettings?.openPasswordModal()"
                    class="px-4 py-2 text-xs font-medium border border-slate-300 rounded-lg hover:border-amber-400 hover:text-amber-700 transition bg-white">
                    Đổi mật khẩu
                  </button>
                </div>
              </div>

              <!-- Active sessions -->
              <div class="p-5 bg-slate-50 rounded-xl">
                <div class="flex items-center justify-between mb-4">
                  <div>
                    <p class="text-sm font-semibold text-slate-700">Phiên đăng nhập</p>
                    <p class="text-xs text-slate-500">Các thiết bị đang đăng nhập</p>
                  </div>
                </div>
                <div class="space-y-3" id="sessions-list">
                  <div class="flex items-center justify-between py-3 border-b border-slate-200 last:border-0">
                    <div class="flex items-center gap-3">
                      <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center">
                        <svg class="w-4.5 h-4.5 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                      </div>
                      <div>
                        <p class="text-sm font-medium text-slate-700">Windows · Chrome</p>
                        <p class="text-xs text-slate-400">Hà Nội, Vietnam · IP: 192.168.1.x</p>
                      </div>
                    </div>
                    <span class="ccec-badge ccec-badge-amber text-xs">Hiện tại</span>
                  </div>
                  <div class="flex items-center justify-between py-3 border-b border-slate-200 last:border-0">
                    <div class="flex items-center gap-3">
                      <div class="w-9 h-9 rounded-lg bg-slate-100 flex items-center justify-center">
                        <svg class="w-4.5 h-4.5 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                      </div>
                      <div>
                        <p class="text-sm font-medium text-slate-700">iOS · Safari</p>
                        <p class="text-xs text-slate-400">TP. Hồ Chí Minh · 2 giờ trước</p>
                      </div>
                    </div>
                    <button onclick="window.ccecSettings?.revokeSession(this)" class="text-xs text-red-500 hover:text-red-700 font-medium transition">Thu hồi</button>
                  </div>
                </div>
              </div>

              <!-- 2FA -->
              <div class="flex items-center justify-between p-5 bg-slate-50 rounded-xl">
                <div>
                  <p class="text-sm font-semibold text-slate-700">Xác thực hai yếu tố (2FA)</p>
                  <p class="text-xs text-slate-500">Bảo vệ tài khoản bằng mã OTP qua điện thoại</p>
                </div>
                <span class="ccec-badge ccec-badge-amber text-xs">Chưa bật</span>
              </div>
            </div>
          </div>

          <!-- ================================================
               TAB 5: API KEYS
               ================================================ -->
          <div id="tab-panel-apikeys" style="display:none">
            <div class="p-6 space-y-6">
              <div class="flex items-center justify-between">
                <div>
                  <h2 class="text-base font-semibold text-slate-800">API Keys</h2>
                  <p class="text-xs text-slate-500 mt-0.5">Quản lý khoá API cho AI và dịch vụ bên thứ ba</p>
                </div>
                <button onclick="window.ccecSettings?.openApiKeyModal()"
                  class="px-4 py-2 bg-[#00E5A0] text-[#0B0F1A] font-semibold text-xs rounded-xl hover:bg-[#00C485] transition shadow-sm flex items-center gap-2">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  Thêm API Key
                </button>
              </div>

              <!-- MiniMax -->
              <div class="p-5 border border-slate-200 rounded-xl">
                <div class="flex items-start justify-between">
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-purple-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                    </div>
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <p class="text-sm font-semibold text-slate-800">MiniMax</p>
                        <span class="ccec-badge ccec-badge-green text-xs">Đã kết nối</span>
                      </div>
                      <p class="text-xs text-slate-500">AI chatbot · Climate analysis · MiniMax API</p>
                      <p class="text-xs font-mono text-slate-400 mt-1">sk-cp-•••••••••••••••</p>
                    </div>
                  </div>
                  <button class="text-xs text-red-500 hover:text-red-700 font-medium transition">Xoá</button>
                </div>
              </div>

              <!-- Groq -->
              <div class="p-5 border border-slate-200 rounded-xl">
                <div class="flex items-start justify-between">
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl bg-orange-50 flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 text-orange-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/></svg>
                    </div>
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <p class="text-sm font-semibold text-slate-800">Groq</p>
                        <span class="ccec-badge ccec-badge-amber text-xs">Tùy chọn</span>
                      </div>
                      <p class="text-xs text-slate-500">Fast LLM inference · Groq Cloud API</p>
                      <p class="text-xs font-mono text-slate-400 mt-1">gsk_•••••••••••••••</p>
                    </div>
                  </div>
                  <button class="text-xs text-red-500 hover:text-red-700 font-medium transition">Xoá</button>
                </div>
              </div>

              <!-- DeepSeek -->
              <div class="p-5 border border-slate-200 rounded-xl">
                <div class="flex items-start justify-between">
                  <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
