---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Climate Policies — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-indigo-700 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
          <span class="text-slate-300">/</span>
          <span class="font-semibold text-slate-700 text-sm">Climate Policies</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs text-slate-400 hidden md:block">UNFCCC · Climate Watch · OECD</span>
          <a href="/dashboard" class="px-4 py-1.5 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:border-indigo-400 hover:text-indigo-700 transition-all">
            Dashboard
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 py-8 space-y-6">

        <!-- PAGE TITLE -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Climate Policy Analysis</h1>
            <p class="text-sm text-slate-500 mt-0.5">NDC tracking · ETS systems · Carbon pricing · Policy impact</p>
          </div>
          <div class="ccec-badge ccec-badge-indigo text-xs">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            UNFCCC Data
          </div>
        </div>

        <!-- VIETNAM NDC PROGRESS -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-indigo-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">NDC Target 2030</span>
            </div>
            <div class="text-2xl font-bold text-indigo-700">-15.8%</div>
            <div class="text-xs text-slate-400 mt-1">vs BAU baseline</div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Unconditional</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">-9%</div>
            <div class="text-xs text-slate-400 mt-1">Domestic resources</div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Conditional</span>
            </div>
            <div class="text-2xl font-bold text-emerald-600">-27%</div>
            <div class="text-xs text-slate-400 mt-1">With international support</div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Net-Zero Target</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">2050</div>
            <div class="text-xs text-slate-400 mt-1">Carbon neutrality goal</div>
          </div>
        </div>

        <!-- NDC COMPARISON TABLE -->
        <div class="ccec-card overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100">
            <h3 class="font-semibold text-slate-800">ASEAN NDC Progress Tracker</h3>
            <p class="text-xs text-slate-400 mt-0.5">NDC submission status · targets vs BAU baseline</p>
          </div>
          <div class="overflow-x-auto">
            <table class="ccec-table">
              <thead>
                <tr>
                  <th class="text-left">Country</th>
                  <th class="text-center">NDC Status</th>
                  <th class="text-right">Unconditional</th>
                  <th class="text-right">Conditional</th>
                  <th class="text-center">Carbon Pricing</th>
                  <th class="text-center">Net-Zero</th>
                  <th class="text-center">Track</th>
                </tr>
              </thead>
              <tbody id="ndc-tbody">
                <tr><td colspan="7" class="text-center py-8 text-slate-400 text-sm">Loading NDC data...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- POLICY FILTER + LIST -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- FILTER SIDEBAR -->
          <div class="ccec-card p-5 h-fit">
            <h3 class="font-semibold text-slate-800 mb-4">Filter Policies</h3>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-slate-500 mb-1.5">Country</label>
                <select id="filter-policy-country" class="w-full ccec-input text-sm py-1.5 px-3 border border-slate-200 rounded-lg focus:border-indigo-400 focus:outline-none">
                  <option value="">All Countries</option>
                  <option value="VNM" selected>Vietnam</option>
                  <option value="THA">Thailand</option>
                  <option value="IDN">Indonesia</option>
                  <option value="PHL">Philippines</option>
                  <option value="MYS">Malaysia</option>
                  <option value="SGP">Singapore</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-slate-500 mb-1.5">Policy Type</label>
                <select id="filter-policy-type" class="w-full ccec-input text-sm py-1.5 px-3 border border-slate-200 rounded-lg focus:border-indigo-400 focus:outline-none">
                  <option value="">All Types</option>
                  <option value="Regulation">Regulation</option>
                  <option value="Tax">Tax/levy</option>
                  <option value="Subsidy">Subsidy/incentive</option>
                  <option value="ETS">Emissions Trading</option>
                  <option value="Information">Information/MRT</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-slate-500 mb-1.5">Sector</label>
                <select id="filter-sector" class="w-full ccec-input text-sm py-1.5 px-3 border border-slate-200 rounded-lg focus:border-indigo-400 focus:outline-none">
                  <option value="">All Sectors</option>
                  <option value="Energy">Energy</option>
                  <option value="Transport">Transport</option>
                  <option value="Industry">Industry</option>
                  <option value="Agriculture">Agriculture</option>
                  <option value="Waste">Waste</option>
                </select>
              </div>
              <button id="apply-policy-filters" class="w-full mt-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
                Apply Filters
              </button>
              <button id="reset-policy-filters" class="w-full px-4 py-2 text-slate-500 text-sm border border-slate-200 rounded-lg hover:border-indigo-400 hover:text-indigo-600 transition-all">
                Reset
              </button>
            </div>

            <!-- CARBON PRICING QUICK STATS -->
            <div class="mt-6 pt-5 border-t border-slate-100">
              <h4 class="font-medium text-slate-700 text-sm mb-3">Carbon Pricing Snapshot</h4>
              <div class="space-y-2.5">
                <div class="flex justify-between text-xs"><span class="text-slate-500">Active ETS worldwide</span><span class="font-semibold text-indigo-600">36</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-500">Countries with carbon tax</span><span class="font-semibold text-indigo-600">30+</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-500">Global carbon price avg</span><span class="font-semibold text-amber-600">$32/tCO₂</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-500">SBTi-aligned price range</span><span class="font-semibold text-emerald-600">$60–100</span></div>
              </div>
            </div>
          </div>

          <!-- POLICY LIST -->
          <div class="lg:col-span-2 space-y-3">
            <div class="ccec-card p-4 flex items-center justify-between">
              <div>
                <h3 class="font-semibold text-slate-800">Policy Registry</h3>
                <p class="text-xs text-slate-400 mt-0.5">Climate policies by country · ICAP database</p>
              </div>
              <span class="text-xs text-slate-400" id="policy-count">— policies</span>
            </div>

            <div id="policy-list">
              <!-- Filled by JS -->
            </div>
          </div>
        </div>

        <!-- CARBON PRICING MAP PLACEHOLDER -->
        <div class="ccec-card p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-slate-800">Global Carbon Pricing Map</h3>
              <p class="text-xs text-slate-400 mt-0.5">ETS jurisdictions · Carbon tax schemes · ICAP registry</p>
            </div>
          </div>
          <div id="policy-map" class="w-full rounded-xl overflow-hidden" style="height: 380px; background: #f8fafc; display: flex; align-items: center; justify-content: center;">
            <div class="text-center text-slate-400">
              <svg class="w-10 h-10 mx-auto mb-2 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <p class="text-sm">Map integration pending<br/><span class="text-xs">Use Leaflet + OpenStreetMap (see MAR-848)</span></p>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>

<script>
const API_BASE = (import.meta as any).env?.PUBLIC_API_URL || 'http://localhost:8000';

function getToken() {
  try {
    const raw = localStorage.getItem('ccec_tokens');
    if (raw) return JSON.parse(raw).access_token;
  } catch {}
  return '';
}

// Sample NDC data
const ndcData = [
  { country: 'Vietnam', code: 'VNM', status: '3rd NDC', unconditional: '-9%', conditional: '-27%', carbonPricing: 'ETS planned', netZero: '2050', track: 'at_risk' },
  { country: 'Thailand', code: 'THA', status: '2nd NDC', unconditional: '-30%', conditional: '-40%', carbonPricing: 'ETS active', netZero: '2065', track: 'on_track' },
  { country: 'Indonesia', code: 'IDN', status: '3rd NDC', unconditional: '-31.9%', conditional: '-43.2%', carbonPricing: 'ETS active', netZero: '2060', track: 'at_risk' },
  { country: 'Philippines', code: 'PHL', status: '2nd NDC', unconditional: '-2.5%', conditional: '-75%', carbonPricing: 'None', netZero: '2050', track: 'on_track' },
  { country: 'Malaysia', code: 'MYS', status: '2nd NDC', unconditional: '-45%', conditional: '', carbonPricing: 'Carbon tax', netZero: '2050', track: 'on_track' },
  { country: 'Singapore', code: 'SGP', status: 'Enhanced NDC', unconditional: '-36%', conditional: '', carbonPricing: 'Carbon tax $25', netZero: '2050', track: 'on_track' },
];

const ndcTbody = document.getElementById('ndc-tbody')!;
ndcTbody.innerHTML = ndcData.map(n => `
  <tr class="hover:bg-indigo-50/50 transition-colors">
    <td class="font-medium text-slate-800 text-sm">
      <div class="flex items-center gap-2">
        <span class="text-xs font-mono text-slate-400">${n.code}</span>
        ${n.country}
      </div>
    </td>
    <td class="text-center"><span class="ccec-badge ccec-badge-indigo text-xs">${n.status}</span></td>
    <td class="text-right font-semibold text-slate-700 text-sm">${n.unconditional}</td>
    <td class="text-right font-semibold text-emerald-700 text-sm">${n.conditional || '—'}</td>
    <td class="text-center"><span class="ccec-badge ccec-badge-blue text-xs">${n.carbonPricing}</span></td>
    <td class="text-center font-semibold text-slate-700 text-sm">${n.netZero}</td>
    <td class="text-center">
      <span class="ccec-badge ${n.track === 'on_track' ? 'ccec-badge-green' : 'ccec-badge-amber'} text-xs">
        ${n.track === 'on_track' ? 'On Track' : 'At Risk'}
      </span>
    </td>
  </tr>
`).join('');

// Sample policies
const samplePolicies = [
  { name: 'Vietnam Law on Environmental Protection 2020', country: 'VNM', type: 'Regulation', sector: 'Cross-cutting', coverage: 'Economy-wide', carbonPrice: '$1–5', link: 'https://英文' },
  { name: 'Vietnam Energy Efficiency Law', country: 'VNM', type: 'Regulation', sector: 'Energy', coverage: 'Industry', carbonPrice: 'N/A', link: '' },
  { name: 'EU Emissions Trading System (EU ETS)', country: 'EU', type: 'ETS', sector: 'Energy/Industry', coverage: 'Economy-wide', carbonPrice: '€68.40', link: '' },
  { name: 'China National ETS', country: 'CHN', type: 'ETS', sector: 'Power', coverage: 'Power sector', carbonPrice: '¥78.50', link: '' },
  { name: 'California Cap-and-Trade', country: 'USA', type: 'ETS', sector: 'Cross-cutting', coverage: 'Economy-wide', carbonPrice: '$35.80', link: '' },
];

async function loadPolicies() {
  const list = document.getElementById('policy-list')!;
  const countEl = document.getElementById('policy-count')!;
  const country = (document.getElementById('filter-policy-country') as HTMLSelectElement).value;
  const policyType = (document.getElementById('filter-policy-type') as HTMLSelectElement).value;
  const sector = (document.getElementById('filter-sector') as HTMLSelectElement).value;

  try {
    const params = new URLSearchParams({ page: '1', page_size: '20' });
    if (country && country !== 'VNM') params.set('country_code', country);
    if (policyType) params.set('policy_type', policyType);
    if (sector) params.set('sector', sector);

    const res = await fetch(`${API_BASE}/api/v1/policies?${params}`, {
      headers: { Authorization: `Bearer ${getToken()}` },
    });
    if (!res.ok) throw new Error('API offline');
    const policies: any[] = await res.json();

    countEl.textContent = `${policies.length} policies`;

    if (policies.length === 0) {
      list.innerHTML = '<div class="ccec-card p-8 text-center text-slate-400 text-sm">No policies found. Try different filters.</div>';
      return;
    }

    list.innerHTML = policies.map(p => `
      <div class="ccec-card p-4 hover:border-indigo-300 transition-colors">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-slate-400">${p.country_code}</span>
              <span class="ccec-badge ccec-badge-indigo text-xs">${p.policy_type}</span>
              <span class="ccec-badge ccec-badge-blue text-xs">${p.sector || 'General'}</span>
            </div>
            <h4 class="font-semibold text-slate-800 text-sm truncate">${p.policy_name}</h4>
            <p class="text-xs text-slate-400 mt-0.5">${p.country_name} · ${p.coverage || 'N/A'}</p>
          </div>
          <div class="text-right shrink-0">
            ${p.carbon_price_min_tCO2e || p.carbon_price_max_tCO2e ? `
              <div class="text-sm font-bold text-amber-600">${p.currency || '$'}${p.carbon_price_min_tCO2e || '?'}–${p.carbon_price_max_tCO2e || '?'}</div>
              <div class="text-xs text-slate-400">/tCO₂</div>
            ` : '<span class="text-xs text-slate-400">—</span>'}
          </div>
        </div>
      </div>
    `).join('');
  } catch {
    countEl.textContent = `${samplePolicies.length} policies (sample)`;
    list.innerHTML = samplePolicies.map(p => `
      <div class="ccec-card p-4 hover:border-indigo-300 transition-colors">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-slate-400">${p.country}</span>
              <span class="ccec-badge ccec-badge-indigo text-xs">${p.type}</span>
              <span class="ccec-badge ccec-badge-blue text-xs">${p.sector}</span>
            </div>
            <h4 class="font-semibold text-slate-800 text-sm">${p.name}</h4>
            <p class="text-xs text-slate-400 mt-0.5">${p.coverage || 'Economy-wide'}</p>
          </div>
          <div class="text-right shrink-0">
            ${p.carbonPrice !== 'N/A' ? `
              <div class="text-sm font-bold text-amber-600">${p.carbonPrice}</div>
              <div class="text-xs text-slate-400">/tCO₂</div>
            ` : '<span class="text-xs text-slate-400">—</span>'}
          </div>
        </div>
      </div>
    `).join('');
  }
}

loadPolicies();

document.getElementById('apply-policy-filters')?.addEventListener('click', loadPolicies);
document.getElementById('reset-policy-filters')?.addEventListener('click', () => {
  (['filter-policy-country', 'filter-policy-type', 'filter-sector'] as const).forEach(id => {
    const el = document.getElementById(id) as HTMLSelectElement;
    if (id === 'filter-policy-country') el.value = 'VNM'; else el.value = '';
  });
  loadPolicies();
});
</script>