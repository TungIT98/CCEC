---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatWidget from '../components/chat/ChatWidget.svelte';
import EmissionsChart from '../components/EmissionsChart.svelte';
---

<BaseLayout title="CO₂ Emissions Explorer — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-amber-500 to-amber-700 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
          <span class="text-slate-300">/</span>
          <span class="font-semibold text-slate-700 text-sm">Phát thải CO₂</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs text-slate-400 hidden md:block">IEA · EDGAR v8.0 · Global Carbon Project</span>
          <a href="/dashboard" class="px-4 py-1.5 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:border-amber-400 hover:text-amber-700 transition-all">
            Dashboard
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 py-8 space-y-6">

        <!-- PAGE TITLE -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">CO₂ Emissions Explorer</h1>
            <p class="text-sm text-slate-500 mt-0.5">Dữ liệu quốc tế · Xu hướng theo thời gian · So sánh khu vực</p>
          </div>
          <div class="ccec-badge ccec-badge-amber text-xs">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            NDC tiến độ
          </div>
        </div>

        <!-- STATS BAR -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2a5 5 0 0 0-5 5v6a5 5 0 0 0 10 0V7a5 5 0 0 0-5-5z"/><path d="M12 2v5m0 0l-3-3m3 3l3-3"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Việt Nam 2024</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">372.9 <span class="text-sm font-normal text-slate-400">MtCO₂</span></div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-3 h-3 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              <span class="text-xs text-red-500 font-semibold">+4.7% vs 2023</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">ASEAN 2024</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">1,445.7 <span class="text-sm font-normal text-slate-400">MtCO₂</span></div>
            <div class="flex items-center gap-1 mt-2">
              <span class="text-xs text-slate-400">25.8%</span>
              <span class="text-xs text-slate-400 font-medium">thị phần</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Toàn cầu 2024</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">38.9 <span class="text-sm font-normal text-slate-400">GtCO₂</span></div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-3 h-3 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              <span class="text-xs text-red-500 font-semibold">+1.8% vs 2023</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">NDC Việt Nam</span>
            </div>
            <div class="text-2xl font-bold text-amber-600">-15.8%</div>
            <div class="flex items-center gap-1 mt-2">
              <span class="text-xs text-slate-400">Mục tiêu 2030</span>
            </div>
          </div>
        </div>

        <!-- CHART -->
        <div class="ccec-card p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-slate-800">Phát thải theo thời gian và ngành</h3>
              <p class="text-xs text-slate-400 mt-0.5">Xu hướng 2019–2024 · Việt Nam & khu vực ASEAN</p>
            </div>
            <div class="flex gap-3 text-xs text-slate-500">
              <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-amber-600 inline-block"></span> Việt Nam</span>
              <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-blue-400 inline-block"></span> ASEAN</span>
              <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-slate-400 inline-block"></span> Global</span>
            </div>
          </div>
          <EmissionsChart client:load />
        </div>

        <!-- COUNTRY COMPARISON TABLE -->
        <div class="ccec-card overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100">
            <h3 class="font-semibold text-slate-800">So sánh khu vực Đông Nam Á</h3>
            <p class="text-xs text-slate-400 mt-0.5">NDC targets và CAGR 5 năm</p>
          </div>
          <div class="overflow-x-auto">
            <table class="ccec-table">
              <thead>
                <tr>
                  <th class="text-left">Quốc gia</th>
                  <th class="text-right">2024 (MtCO₂)</th>
                  <th class="text-right">CAGR 5y</th>
                  <th class="text-right">NDC mục tiêu</th>
                  <th class="text-center">Trạng thái</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { country: 'Việt Nam', flag: 'VN', value: '372.9', cagr: '+5.8%', cagrNeg: true, ndc: '-15.8% (2030)', ndcOk: true },
                  { country: 'Thái Lan', flag: 'TH', value: '289.4', cagr: '+3.1%', cagrNeg: true, ndc: '-30% (2030)', ndcOk: true },
                  { country: 'Indonesia', flag: 'ID', value: '621.7', cagr: '+2.9%', cagrNeg: true, ndc: '-31% (2030)', ndcOk: true },
                  { country: 'Philippines', flag: 'PH', value: '148.3', cagr: '+4.2%', cagrNeg: true, ndc: '-2.5% (2030)', ndcOk: false },
                  { country: 'Malaysia', flag: 'MY', value: '263.8', cagr: '+2.1%', cagrNeg: true, ndc: '-45% (2030)', ndcOk: true },
                ].map(r => (
                  <tr>
                    <td class="font-medium text-slate-700">{r.country}</td>
                    <td class="text-right font-semibold text-slate-800">{r.value}</td>
                    <td class={`text-right font-semibold ${r.cagrNeg ? 'text-red-500' : 'text-emerald-600'}`}>{r.cagr}</td>
                    <td class="text-right text-amber-600 font-medium">{r.ndc}</td>
                    <td class="text-center">
                      <span class={`ccec-badge text-xs ${r.ndcOk ? 'ccec-badge-green' : 'ccec-badge-amber'}`}>
                        {r.ndcOk ? 'On track' : 'At risk'}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="px-5 py-3 border-t border-slate-100 bg-slate-50">
            <p class="text-xs text-slate-400">CAGR: Compound Annual Growth Rate. NDC targets relative to BAU baseline.</p>
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>