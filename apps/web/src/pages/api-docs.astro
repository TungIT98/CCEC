---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="API Docs — CCEC Climate Platform">
  <div class="min-h-screen bg-slate-50">
    <header class="bg-teal-700 text-white shadow">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-4">
        <a href="/" class="text-teal-200 hover:text-white text-sm">← Trang chủ</a>
        <span class="text-teal-400">|</span>
        <h1 class="font-semibold">API Documentation</h1>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-12">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
        <h2 class="text-2xl font-bold text-slate-800 mb-2">API Documentation</h2>
        <p class="text-slate-500 mb-8">CCEC Climate Platform · FastAPI · Swagger/OpenAPI</p>

        <div class="space-y-4">
          <div class="p-4 bg-teal-50 border border-teal-200 rounded-xl">
            <h3 class="font-semibold text-slate-800 mb-1">Swagger UI</h3>
            <p class="text-sm text-slate-500 mb-3">Interactive API explorer — đăng nhập với JWT token</p>
            <a href="/docs" class="inline-flex items-center gap-2 bg-teal-700 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-teal-800 transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Mở Swagger UI
            </a>
          </div>

          <div class="p-4 bg-slate-50 border border-slate-200 rounded-xl">
            <h3 class="font-semibold text-slate-800 mb-1">ReDoc</h3>
            <p class="text-sm text-slate-500 mb-3">Beautiful API documentation — read-only</p>
            <a href="/redoc" class="inline-flex items-center gap-2 bg-slate-700 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-800 transition">
              📖 Mở ReDoc
            </a>
          </div>

          <div class="p-4 border border-slate-200 rounded-xl">
            <h3 class="font-semibold text-slate-800 mb-1">OpenAPI Schema</h3>
            <p class="text-sm text-slate-500 mb-3">Machine-readable spec (JSON)</p>
            <a href="/openapi.json" class="inline-flex items-center gap-2 border border-slate-300 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 transition">
              /openapi.json
            </a>
          </div>
        </div>

        <hr class="my-8 border-slate-100" />

        <h3 class="font-semibold text-slate-800 mb-4">Quick Reference</h3>
        <div class="space-y-3 text-sm">
          <div class="flex gap-3">
            <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded font-mono text-xs">GET</span>
            <code class="text-slate-600">/api/v1/emissions?year=2024</code>
            <span class="text-slate-400">— Public emissions by province (no auth)</span>
          </div>
          <div class="flex gap-3">
            <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded font-mono text-xs">GET</span>
            <code class="text-slate-600">/api/v1/emissions/trends</code>
            <span class="text-slate-400">— Public emissions trend time-series</span>
          </div>
          <div class="flex gap-3">
            <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded font-mono text-xs">GET</span>
            <code class="text-slate-600">/api/v1/emissions/carbon-credits</code>
            <span class="text-slate-400">— Public carbon credit registry</span>
          </div>
          <div class="flex gap-3">
            <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-mono text-xs">POST</span>
            <code class="text-slate-600">/api/v1/auth/login/json</code>
            <span class="text-slate-400">— Login (returns JWT)</span>
          </div>
          <div class="flex gap-3">
            <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-mono text-xs">POST</span>
            <code class="text-slate-600">/api/v1/auth/register</code>
            <span class="text-slate-400">— Create account</span>
          </div>
          <div class="flex gap-3">
            <span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded font-mono text-xs">GET</span>
            <code class="text-slate-600">/api/v1/climate/data</code>
            <span class="text-slate-400">— Climate data (auth required)</span>
          </div>
          <div class="flex gap-3">
            <span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded font-mono text-xs">GET</span>
            <code class="text-slate-600">/api/v1/climate/forecast</code>
            <span class="text-slate-400">— Weather forecast (auth required)</span>
          </div>
          <div class="flex gap-3">
            <span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded font-mono text-xs">POST</span>
            <code class="text-slate-600">/api/v1/chat</code>
            <span class="text-slate-400">— AI chat (auth required)</span>
          </div>
        </div>

        <hr class="my-8 border-slate-100" />

        <h3 class="font-semibold text-slate-800 mb-3">Base URL</h3>
        <div class="bg-slate-100 rounded-lg px-4 py-3 font-mono text-sm text-slate-700">
          http://localhost:8000
        </div>
        <p class="text-xs text-slate-400 mt-2">Set <code class="bg-slate-100 px-1 rounded">PUBLIC_API_URL</code> env var to change base URL in frontend.</p>
      </div>
    </main>
  </div>
</BaseLayout>