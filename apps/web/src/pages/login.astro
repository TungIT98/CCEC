---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Đăng nhập — CCEC Climate Platform">
  <div class="min-h-screen bg-gradient-to-br from-teal-700 via-teal-600 to-emerald-700 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-3 mb-4">
          <div class="w-12 h-12 rounded-xl bg-teal-500 flex items-center justify-center font-bold text-2xl text-white shadow-lg">
            CCEC
          </div>
        </div>
        <h1 class="text-2xl font-bold text-white">CCEC Climate Platform</h1>
        <p class="text-teal-200 mt-1 text-sm">Đăng nhập để truy cập dashboard khí hậu</p>
      </div>

      <!-- Login Card -->
      <div class="bg-white rounded-2xl shadow-2xl p-8">
        <h2 class="text-xl font-bold text-slate-800 mb-6">Đăng nhập</h2>

        <form id="login-form" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
            <input
              id="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none transition text-sm"
            />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Mật khẩu</label>
            <input
              id="password"
              type="password"
              required
              autocomplete="current-password"
              placeholder="••••••••"
              class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none transition text-sm"
            />
          </div>

          <div id="form-error" class="hidden text-sm text-red-600 bg-red-50 rounded-lg px-4 py-2"></div>

          <button
            id="login-btn"
            type="submit"
            class="w-full bg-teal-700 text-white py-2.5 rounded-lg font-semibold hover:bg-teal-800 transition disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Đăng nhập
          </button>
        </form>

        <div class="mt-4 text-center">
          <p class="text-sm text-slate-500">
            Chưa có tài khoản?
            <button id="register-toggle" class="text-teal-700 hover:underline font-medium">Đăng ký ngay</button>
          </p>
        </div>

        <!-- Register form (hidden by default) -->
        <form id="register-form" class="hidden space-y-4 mt-6 pt-6 border-t border-slate-100">
          <h3 class="text-sm font-semibold text-slate-700">Tạo tài khoản mới</h3>
          <div>
            <label for="reg-email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
            <input
              id="reg-email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none transition text-sm"
            />
          </div>
          <div>
            <label for="reg-password" class="block text-sm font-medium text-slate-700 mb-1">Mật khẩu</label>
            <input
              id="reg-password"
              type="password"
              required
              autocomplete="new-password"
              placeholder="•••••••• (tối thiểu 8 ký tự)"
              minlength="8"
              class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 outline-none transition text-sm"
            />
          </div>
          <div id="reg-error" class="hidden text-sm text-red-600 bg-red-50 rounded-lg px-4 py-2"></div>
          <div id="reg-success" class="hidden text-sm text-green-700 bg-green-50 rounded-lg px-4 py-2"></div>
          <button
            id="register-btn"
            type="submit"
            class="w-full bg-teal-100 text-teal-800 py-2.5 rounded-lg font-semibold hover:bg-teal-200 transition disabled:opacity-50"
          >
            Tạo tài khoản
          </button>
          <p class="text-center">
            <button id="login-toggle" class="text-sm text-slate-500 hover:underline">← Quay lại đăng nhập</button>
          </p>
        </form>

        <div class="mt-6 pt-4 border-t border-slate-100">
          <p class="text-xs text-slate-400 text-center">
            <a href="/" class="hover:text-teal-600">← Quay về trang chủ</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';

  // Toggle forms
  document.getElementById('register-toggle')?.addEventListener('click', () => {
    document.getElementById('login-form')?.classList.add('hidden');
    document.getElementById('register-form')?.classList.remove('hidden');
  });
  document.getElementById('login-toggle')?.addEventListener('click', () => {
    document.getElementById('register-form')?.classList.add('hidden');
    document.getElementById('login-form')?.classList.remove('hidden');
  });

  // Login
  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const btn = document.getElementById('login-btn') as HTMLButtonElement;
    const errEl = document.getElementById('form-error')!;

    btn.disabled = true;
    btn.textContent = 'Đang đăng nhập...';
    errEl.classList.add('hidden');

    try {
      const res = await fetch(`${API_BASE}/api/v1/auth/login/json`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail || 'Đăng nhập thất bại. Vui lòng kiểm tra email và mật khẩu.');
      }
      const tokens = await res.json();
      // Store tokens — access token expires in 60 min (backend ACCESS_TOKEN_EXPIRE_MINUTES=60)
      localStorage.setItem('ccec_tokens', JSON.stringify({
        ...tokens,
        expires_at: Date.now() + 60 * 60 * 1000,
      }));
      // Fetch user profile
      const meRes = await fetch(`${API_BASE}/api/v1/users/me`, {
        headers: { Authorization: `Bearer ${tokens.access_token}` },
      });
      if (meRes.ok) {
        const user = await meRes.json();
        localStorage.setItem('ccec_user', JSON.stringify(user));
      }
      // Redirect
      window.location.href = '/dashboard';
    } catch (err: any) {
      errEl.textContent = err.message || 'Lỗi kết nối. Vui lòng thử lại.';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Đăng nhập';
    }
  });

  // Register
  document.getElementById('register-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('reg-email') as HTMLInputElement).value;
    const password = (document.getElementById('reg-password') as HTMLInputElement).value;
    const btn = document.getElementById('register-btn') as HTMLButtonElement;
    const errEl = document.getElementById('reg-error')!;
    const successEl = document.getElementById('reg-success')!;

    btn.disabled = true;
    btn.textContent = 'Đang đăng ký...';
    errEl.classList.add('hidden');
    successEl.classList.add('hidden');

    try {
      const res = await fetch(`${API_BASE}/api/v1/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail || 'Đăng ký thất bại.');
      }
      successEl.textContent = 'Đăng ký thành công! Vui lòng đăng nhập.';
      successEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Tạo tài khoản';
      // Switch to login after short delay
      setTimeout(() => {
        document.getElementById('login-form')?.classList.remove('hidden');
        document.getElementById('register-form')?.classList.add('hidden');
        (document.getElementById('email') as HTMLInputElement).value = email;
        (document.getElementById('password') as HTMLInputElement).value = password;
      }, 1500);
    } catch (err: any) {
      errEl.textContent = err.message || 'Lỗi kết nối. Vui lòng thử lại.';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Tạo tài khoản';
    }
  });
</script>