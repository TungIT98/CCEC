---
import BaseLayout from '../layouts/BaseLayout.astro';
import Chart from '../components/Chart.svelte';
import MapWidget from '../components/MapWidget.svelte';
---

<BaseLayout title="Dashboard — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- ============================================================
         NAVBAR — Sticky glassmorphism header (matches landing page)
         ============================================================ -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <!-- Logo + breadcrumb -->
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-teal-500 to-teal-700 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
          <span class="text-slate-300">/</span>
          <span class="font-semibold text-slate-700 text-sm">Dashboard Khí hậu</span>
        </div>
        <!-- Right: user info + login -->
        <div class="flex items-center gap-3">
          <span id="user-display" class="text-sm text-slate-500 hidden md:block"></span>
          <div id="auth-banner" class="hidden ccec-badge ccec-badge-amber mr-2">
            Chưa đăng nhập
          </div>
          <a href="/login" class="px-4 py-1.5 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:border-teal-400 hover:text-teal-700 transition-all">
            Đăng nhập
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 py-8 space-y-6">

        <!-- ============================================================
             PAGE TITLE + LIVE INDICATOR
             ============================================================ -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Dashboard Khí hậu</h1>
            <p class="text-sm text-slate-500 mt-0.5">Dữ liệu thời gian thực · Cập nhật 30 giây</p>
          </div>
          <div class="flex items-center gap-2 ccec-badge ccec-badge-green">
            <span class="status-dot status-dot-live"></span>
            Live
          </div>
        </div>

        <!-- ============================================================
             KPI CARDS — Modern gradient cards with trend indicators
             ============================================================ -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="ccec-card p-5">
            <div class="flex items-center justify-between mb-3">
              <div class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2a5 5 0 0 0-5 5v6a5 5 0 0 0 10 0V7a5 5 0 0 0-5-5z"/>
                  <path d="M12 2v5m0 0l-3-3m3 3l3-3"/>
                </svg>
              </div>
              <span class="ccec-badge ccec-badge-green text-xs">Hà Nội</span>
            </div>
            <div class="text-2xl font-bold text-slate-900" id="kpi-temp">— °C</div>
            <div class="text-xs text-slate-500 mt-1">Nhiệt độ trung bình</div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center justify-between mb-3">
              <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                </svg>
              </div>
              <span class="ccec-badge ccec-badge-blue text-xs">Tháng này</span>
            </div>
            <div class="text-2xl font-bold text-slate-900" id="kpi-rain">— mm</div>
            <div class="text-xs text-slate-500 mt-1">Lượng mưa</div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center justify-between mb-3">
              <div class="w-9 h-9 rounded-xl bg-purple-50 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-purple-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                </svg>
              </div>
              <span class="ccec-badge ccec-badge-teal text-xs">Trung bình</span>
            </div>
            <div class="text-2xl font-bold text-slate-900" id="kpi-humidity">— %</div>
            <div class="text-xs text-slate-500 mt-1">Độ ẩm</div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center justify-between mb-3">
              <div class="w-9 h-9 rounded-xl bg-amber-50 flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 8v4l3 3"/>
                </svg>
              </div>
              <span class="ccec-badge ccec-badge-amber text-xs">Toàn cầu</span>
            </div>
            <div class="text-2xl font-bold text-slate-900" id="kpi-co2">— ppm</div>
            <div class="text-xs text-slate-500 mt-1">Mức CO₂</div>
          </div>
        </div>

        <!-- ============================================================
             CHARTS ROW — Temperature/Rainfall + CO2/Humidity
             ============================================================ -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="ccec-chart-card">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="font-semibold text-slate-800">Nhiệt độ & Lượng mưa</h3>
                <p class="text-xs text-slate-400 mt-0.5">7 ngày gần nhất</p>
              </div>
              <div class="flex gap-3 text-xs text-slate-500">
                <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-teal-600 inline-block"></span> Nhiệt độ</span>
                <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-blue-400 inline-block"></span> Lượng mưa</span>
              </div>
            </div>
            <Chart client:load type="temperature-rainfall" />
          </div>

          <div class="ccec-chart-card">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="font-semibold text-slate-800">CO₂ & Độ ẩm</h3>
                <p class="text-xs text-slate-400 mt-0.5">Xu hướng theo ngày</p>
              </div>
              <div class="flex gap-3 text-xs text-slate-500">
                <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-amber-500 inline-block"></span> CO₂</span>
                <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-purple-400 inline-block"></span> Độ ẩm</span>
              </div>
            </div>
            <Chart client:load type="co2-humidity" />
          </div>
        </div>

        <!-- ============================================================
             EMISSIONS OVERVIEW — Top 5 provinces + total
             ============================================================ -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="ccec-chart-card lg:col-span-2">
            <div class="flex items-center justify-between mb-5">
              <div>
                <h3 class="font-semibold text-slate-800">Phát thải theo Tỉnh/Thành</h3>
                <p class="text-xs text-slate-400 mt-0.5">Top 5 — kt CO₂ · Năm 2024</p>
              </div>
              <a href="/emissions" class="text-xs text-teal-600 font-medium hover:text-teal-800 transition flex items-center gap-1">
                Chi tiết
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div id="emissions-bars" class="space-y-3"></div>
            <div id="emissions-bars-loading" class="text-center py-6 text-slate-400 text-sm">Đang tải dữ liệu phát thải...</div>
          </div>

          <div class="space-y-4">
            <!-- Total emissions -->
            <div class="ccec-card p-5">
              <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold mb-2">Tổng phát thải 2024</p>
              <div class="text-4xl font-extrabold text-slate-900 mb-1" id="total-emissions">—</div>
              <p class="text-sm text-slate-500">kt CO₂ cả nước</p>
              <p class="text-xs text-slate-400 mt-2" id="emissions-pct"></p>
            </div>
            <!-- 7-day forecast -->
            <div class="ccec-card p-5">
              <div class="flex items-center justify-between mb-4">
                <h3 class="font-semibold text-slate-800">Dự báo 7 ngày</h3>
                <a href="/maps" class="text-xs text-teal-600 font-medium hover:text-teal-800 transition">Bản đồ</a>
              </div>
              <div id="forecast-list" class="space-y-2"></div>
              <div id="forecast-loading" class="text-center py-6 text-slate-400 text-sm">Đang tải dự báo...</div>
            </div>
          </div>
        </div>

        <!-- ============================================================
             MAP SECTION
             ============================================================ -->
        <div class="ccec-card overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-slate-800">Bản đồ Vietnam</h3>
              <p class="text-xs text-slate-400 mt-0.5">Mapbox · Tầng khí hậu · Ngập lụt · Địa hình</p>
            </div>
            <button onclick="window.ccecRefreshMap?.()" class="text-xs text-teal-600 hover:text-teal-800 font-medium transition flex items-center gap-1">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
              </svg>
              Làm mới
            </button>
          </div>
          <div class="h-96">
            <MapWidget client:load />
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>

<script>
  import { fetchClimateData, fetchForecast, fetchEmissionsSummary } from '../lib/api';

  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
  let refreshTimer: ReturnType<typeof setInterval>;

  // Auth guard — show banner if not logged in
  function checkAuth() {
    const banner = document.getElementById('auth-banner');
    try {
      const raw = localStorage.getItem('ccec_user');
      if (!raw) {
        banner?.classList.remove('hidden');
      }
      const user = raw ? JSON.parse(raw) : null;
      if (user?.email) {
        const el = document.getElementById('user-display');
        if (el) el.textContent = user.email;
      }
    } catch {}
  }

  async function loadDashboard() {
    // Climate data (auth-protected, graceful fallback)
    try {
      const data = await fetchClimateData(21.0285, 105.8542, 50);
      if (data.length > 0) {
        const latest = data[data.length - 1];
        document.getElementById('kpi-temp')!.textContent = latest.temperature.toFixed(1) + ' °C';
        document.getElementById('kpi-rain')!.textContent = latest.rainfall.toFixed(0) + ' mm';
        document.getElementById('kpi-humidity')!.textContent = latest.humidity.toFixed(0) + ' %';
        document.getElementById('kpi-co2')!.textContent = latest.co2_level.toFixed(0) + ' ppm';
      }
    } catch {
      document.getElementById('kpi-temp')!.textContent = '28.5 °C';
      document.getElementById('kpi-rain')!.textContent = '4 mm';
      document.getElementById('kpi-humidity')!.textContent = '75 %';
      document.getElementById('kpi-co2')!.textContent = '425 ppm';
    }

    // Forecast (auth-protected, graceful fallback)
    try {
      const forecast = await fetchForecast('Hanoi', 7);
      const list = document.getElementById('forecast-list');
      const loading = document.getElementById('forecast-loading');
      if (loading) loading.style.display = 'none';
      forecast.forEach(day => {
        const div = document.createElement('div');
        div.className = 'flex items-center justify-between py-2 border-b border-slate-100 last:border-0';
        div.innerHTML = `
          <div class="text-sm font-medium text-slate-700">${day.date}</div>
          <div class="flex items-center gap-3 text-xs">
            <span class="flex items-center gap-1 text-red-500">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2a5 5 0 0 0-5 5v6a5 5 0 0 0 10 0V7a5 5 0 0 0-5-5z"/></svg>
              ${day.temp_max.toFixed(0)}°
            </span>
            <span class="flex items-center gap-1 text-blue-500">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
              ${day.temp_min.toFixed(0)}°
            </span>
            <span class="text-slate-400">${(day.rainfall_prob * 100).toFixed(0)}%</span>
          </div>`;
        list?.appendChild(div);
      });
    } catch {
      const loading = document.getElementById('forecast-loading');
      if (loading) loading.textContent = 'Không có dữ liệu (cần đăng nhập)';
    }

    // Emissions (public, no auth needed)
    try {
      const emData = await fetchEmissionsSummary(2024);
      const loading = document.getElementById('emissions-bars-loading');
      if (loading) loading.style.display = 'none';

      const total = emData.total_emissions_kt;
      document.getElementById('total-emissions')!.textContent = total > 0
        ? (total / 1000).toFixed(1) + 'K'
        : '—';
      document.getElementById('emissions-pct')!.textContent = `${emData.provinces?.length ?? 0} tỉnh/thành được giám sát`;

      const container = document.getElementById('emissions-bars');
      const top5 = (emData.provinces ?? []).slice(0, 5);
      top5.forEach((prov, i) => {
        const pct = Math.min((prov.emissions_kt / total) * 100, 100);
        const colors = ['#0D9488', '#3B82F6', '#6366F1', '#8B5CF6', '#EC4899'];
        const bar = document.createElement('div');
        bar.className = 'group';
        bar.innerHTML = `
          <div class="flex items-center justify-between mb-1">
            <span class="text-sm font-medium text-slate-700">${prov.name}</span>
            <span class="text-xs font-semibold text-slate-600">${prov.emissions_kt.toLocaleString()} kt</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex-1 bg-slate-100 rounded-full h-2 overflow-hidden">
              <div class="h-full rounded-full transition-all duration-700" style="width:${pct.toFixed(0)}%;background:${colors[i % colors.length]}"></div>
            </div>
            <span class="text-xs text-slate-400 w-8 text-right">${pct.toFixed(0)}%</span>
          </div>`;
        container?.appendChild(bar);
      });
    } catch {
      const loading = document.getElementById('emissions-bars-loading');
      if (loading) loading.textContent = 'Không tải được dữ liệu phát thải.';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    checkAuth();
    loadDashboard();
    refreshTimer = setInterval(loadDashboard, 30_000);
  });
  window.addEventListener('unload', () => { clearInterval(refreshTimer); });
</script>
