---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Carbon Credits — CCEC Climate Platform">
  <div class="min-h-screen flex flex-col">

    <!-- NAVBAR -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-slate-200/80">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center shadow-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <span class="font-bold text-slate-900 text-sm">CCEC</span>
          </a>
          <span class="text-slate-300">/</span>
          <span class="font-semibold text-slate-700 text-sm">Carbon Credits</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs text-slate-400 hidden md:block">ICAP · Verra · Ecosystem Marketplace</span>
          <a href="/dashboard" class="px-4 py-1.5 text-sm font-medium text-slate-600 border border-slate-300 rounded-lg hover:border-emerald-400 hover:text-emerald-700 transition-all">
            Dashboard
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 py-8 space-y-6">

        <!-- PAGE TITLE -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Carbon Credit Market</h1>
            <p class="text-sm text-slate-500 mt-0.5">Verra Gold Standard · ICAP ETS · EU Compliance Markets</p>
          </div>
          <div class="ccec-badge ccec-badge-green text-xs">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Live Registry
          </div>
        </div>

        <!-- STATS BAR -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Global Credits</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">218.4 <span class="text-sm font-normal text-slate-400">MtCO₂</span></div>
            <div class="flex items-center gap-1 mt-2">
              <span class="text-xs text-slate-400">Registered 2024</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Avg Price</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">$14.80 <span class="text-sm font-normal text-slate-400">/tCO₂</span></div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-3 h-3 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
              <span class="text-xs text-emerald-600 font-semibold">+6.2% vs 2023</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">EU ETS Price</span>
            </div>
            <div class="text-2xl font-bold text-slate-900">€68.40 <span class="text-sm font-normal text-slate-400">/tCO₂</span></div>
            <div class="flex items-center gap-1 mt-2">
              <svg class="w-3 h-3 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/></svg>
              <span class="text-xs text-red-500 font-semibold">-2.1% MTD</span>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Vietnam Credits</span>
            </div>
            <div class="text-2xl font-bold text-purple-600">12.7 <span class="text-sm font-normal text-slate-400">MtCO₂</span></div>
            <div class="flex items-center gap-1 mt-2">
              <span class="text-xs text-slate-400">Verra + Gold Standard</span>
            </div>
          </div>
        </div>

        <!-- PRICE CHART -->
        <div class="ccec-card p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 class="font-semibold text-slate-800">Carbon Price Trends</h3>
              <p class="text-xs text-slate-400 mt-0.5">EU ETS · California · VCER · Verra · Gold Standard (USD/tCO₂)</p>
            </div>
            <div class="flex gap-3 text-xs text-slate-500">
              <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-amber-500 inline-block"></span> EU ETS</span>
              <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-blue-500 inline-block"></span> California</span>
              <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-emerald-500 inline-block"></span> Verra VCU</span>
              <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-purple-500 inline-block"></span> Gold Standard</span>
            </div>
          </div>
          <div id="price-chart" class="w-full" style="height: 280px;"></div>
        </div>

        <!-- FILTER BAR -->
        <div class="ccec-card p-4 flex flex-wrap gap-3 items-center">
          <span class="text-sm font-medium text-slate-700">Filters:</span>
          <select id="filter-standard" class="ccec-input text-sm py-1.5 px-3 border border-slate-200 rounded-lg focus:border-emerald-400 focus:outline-none">
            <option value="">All Standards</option>
            <option value="VER">Verra (VCU)</option>
            <option value="CER">Clean Development Mechanism</option>
            <option value="GOLD">Gold Standard</option>
          </select>
          <select id="filter-vintage" class="ccec-input text-sm py-1.5 px-3 border border-slate-200 rounded-lg focus:border-emerald-400 focus:outline-none">
            <option value="">All Vintage Years</option>
            <option value="2020">2020</option>
            <option value="2021">2021</option>
            <option value="2022">2022</option>
            <option value="2023">2023</option>
            <option value="2024">2024</option>
          </select>
          <select id="filter-project-type" class="ccec-input text-sm py-1.5 px-3 border border-slate-200 rounded-lg focus:border-emerald-400 focus:outline-none">
            <option value="">All Project Types</option>
            <option value="RE_FOR">Reforestation</option>
            <option value="RE_Wind">Wind Energy</option>
            <option value="RE_Solar">Solar Energy</option>
            <option value="RE_Waste">Waste Management</option>
            <option value="RE_Methane">Methane Capture</option>
          </select>
          <select id="filter-country" class="ccec-input text-sm py-1.5 px-3 border border-slate-200 rounded-lg focus:border-emerald-400 focus:outline-none">
            <option value="">All Countries</option>
            <option value="VNM">Vietnam</option>
            <option value="BRA">Brazil</option>
            <option value="CHN">China</option>
            <option value="IND">India</option>
            <option value="IDN">Indonesia</option>
            <option value="KEN">Kenya</option>
          </select>
          <div class="ml-auto flex items-center gap-2 text-xs text-slate-400">
            <span id="credit-count">— credits</span>
            <button id="reset-filters" class="text-emerald-600 hover:text-emerald-800 font-medium">Reset</button>
          </div>
        </div>

        <!-- CREDIT REGISTRY TABLE -->
        <div class="ccec-card overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-slate-800">Credit Registry</h3>
              <p class="text-xs text-slate-400 mt-0.5">Verified carbon credits · ICAP registry data</p>
            </div>
            <div class="flex gap-2">
              <button class="px-3 py-1.5 text-xs font-medium text-slate-600 border border-slate-200 rounded-lg hover:border-emerald-400 hover:text-emerald-700 transition-all flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export CSV
              </button>
            </div>
          </div>
          <div class="overflow-x-auto">
            <table class="ccec-table">
              <thead>
                <tr>
                  <th class="text-left">Project / Registry</th>
                  <th class="text-center">Standard</th>
                  <th class="text-center">Vintage</th>
                  <th class="text-right">Verified ERt</th>
                  <th class="text-right">Price</th>
                  <th class="text-center">Status</th>
                  <th class="text-left">Country</th>
                </tr>
              </thead>
              <tbody id="credits-tbody">
                <tr><td colspan="7" class="text-center py-8 text-slate-400 text-sm">Loading credit registry...</td></tr>
              </tbody>
            </table>
          </div>
          <div id="pagination-bar" class="px-5 py-3 border-t border-slate-100 flex items-center justify-between">
            <span class="text-xs text-slate-400" id="pagination-info">—</span>
            <div class="flex gap-1" id="pagination-controls"></div>
          </div>
        </div>

        <!-- MARKET SENTIMENT -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Market Sentiment</span>
            </div>
            <div class="text-xl font-bold text-emerald-600">Bullish</div>
            <div class="text-xs text-slate-400 mt-1">Strong demand for compliance credits</div>
            <div class="mt-3 space-y-1.5">
              <div class="flex justify-between text-xs"><span class="text-slate-500">EU compliance</span><span class="font-semibold text-emerald-600">High</span></div>
              <div class="flex justify-between text-xs"><span class="text-slate-500">Voluntary demand</span><span class="font-semibold text-emerald-600">Growing</span></div>
              <div class="flex justify-between text-xs"><span class="text-slate-500">Supply tightness</span><span class="font-semibold text-amber-600">Moderate</span></div>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">ETS Coverage</span>
            </div>
            <div class="text-xl font-bold text-blue-600">36 Jurisdictions</div>
            <div class="text-xs text-slate-400 mt-1">Global Emissions Trading Systems</div>
            <div class="mt-3 space-y-1.5">
              <div class="flex justify-between text-xs"><span class="text-slate-500">EU ETS</span><span class="font-semibold text-blue-600">€68.40</span></div>
              <div class="flex justify-between text-xs"><span class="text-slate-500">California CCA</span><span class="font-semibold text-blue-600">$35.80</span></div>
              <div class="flex justify-between text-xs"><span class="text-slate-500">China ETS</span><span class="font-semibold text-blue-600">¥78.50</span></div>
            </div>
          </div>

          <div class="ccec-card p-5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <span class="text-xs font-medium text-slate-500">Vietnam REDD+</span>
            </div>
            <div class="text-xl font-bold text-amber-600">1.8M ha</div>
            <div class="text-xs text-slate-400 mt-1">Forests under REDD+ programs</div>
            <div class="mt-3 space-y-1.5">
              <div class="flex justify-between text-xs"><span class="text-slate-500">Verra VCS projects</span><span class="font-semibold text-amber-600">24 active</span></div>
              <div class="flex justify-between text-xs"><span class="text-slate-500">Gold Standard</span><span class="font-semibold text-amber-600">8 projects</span></div>
              <div class="flex justify-between text-xs"><span class="text-slate-500">Credits issued</span><span class="font-semibold text-amber-600">12.7 MtCO₂</span></div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</BaseLayout>

<script>
import * as echarts from 'echarts';

// Token for auth
function getToken() {
  try {
    const raw = localStorage.getItem('ccec_tokens');
    if (raw) return JSON.parse(raw).access_token;
  } catch {}
  return '';
}
function authHeaders() {
  const token = getToken();
  return token ? { Authorization: `Bearer ${token}` } : {};
}
const standardColors: Record<string, string> = {
  'EU ETS': '#f59e0b',
  'California': '#3b82f6',
  'VCER': '#10b981',
  'Verra VCU': '#10b981',
  'Gold Standard': '#8b5cf6',
  'CDM': '#f97316',
};

// Price chart
const API_BASE = import.meta.env?.PUBLIC_API_URL || 'http://localhost:8000';
const chartDom = document.getElementById('price-chart')!;
const chart = echarts.init(chartDom);

// Sample price history (12 months)
function tooltipFormatter(params: any) {
  let result = params[0].axisValue + '<br/>';
  params.forEach((x: any) => {
    result += '<span style="color:' + x.color + '">\u25CF</span> ' + x.seriesName + ': <b>$' + x.value + '</b>/tCO2<br/>';
  });
  return result;
}
const months = ['Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar', 'Apr', 'May'];
const series: echarts.EChartOption.Series[] = [
  { name: 'EU ETS', type: 'line', data: [42.1, 45.3, 51.8, 58.2, 62.4, 65.1, 68.9, 67.3, 69.8, 68.4, 69.1, 68.4], smooth: true, lineStyle: { width: 2 }, symbol: 'circle', symbolSize: 4 },
  { name: 'California', type: 'line', data: [28.5, 29.1, 31.2, 33.8, 34.5, 35.2, 36.1, 35.8, 36.4, 35.9, 36.2, 35.8], smooth: true, lineStyle: { width: 2 }, symbol: 'circle', symbolSize: 4 },
  { name: 'Verra VCU', type: 'line', data: [8.2, 9.1, 10.4, 11.8, 12.3, 13.1, 14.2, 13.8, 14.5, 14.9, 15.1, 14.8], smooth: true, lineStyle: { width: 2 }, symbol: 'circle', symbolSize: 4 },
  { name: 'Gold Standard', type: 'line', data: [9.5, 10.2, 11.3, 12.1, 12.8, 13.4, 14.1, 13.9, 14.6, 15.0, 15.3, 15.1], smooth: true, lineStyle: { width: 2 }, symbol: 'circle', symbolSize: 4 },
].map(s => ({
  ...s,
  data: (s.data as number[]).map(v => v.toFixed(1)),
  itemStyle: { color: standardColors[s.name as string] || '#888' },
  emphasis: { lineStyle: { width: 3 } },
})) as any;

chart.setOption({
  backgroundColor: 'transparent',
  tooltip: { trigger: 'axis', formatter: 'tooltipFormatter' },
  legend: { show: false },
  grid: { left: 50, right: 20, top: 10, bottom: 30 },
  xAxis: { type: 'category', data: months, axisLine: { lineStyle: { color: '#e2e8f0' } }, axisLabel: { color: '#94a3b8', fontSize: 11 } },
  yAxis: { type: 'value', axisLine: { show: false }, splitLine: { lineStyle: { color: '#f1f5f9' } }, axisLabel: { color: '#94a3b8', fontSize: 11, formatter: "v => '$' + v" } },
  series,
});

window.addEventListener('resize', () => chart.resize());

// Credits table
let currentPage = 1;
const pageSize = 20;

async function loadCredits() {
  const tbody = document.getElementById('credits-tbody')!;
  const countEl = document.getElementById('credit-count')!;

  const params = new URLSearchParams({
    page: String(currentPage),
    page_size: String(pageSize),
  });

  const standard = (document.getElementById('filter-standard') as HTMLSelectElement).value;
  const vintage = (document.getElementById('filter-vintage') as HTMLSelectElement).value;
  const projectType = (document.getElementById('filter-project-type') as HTMLSelectElement).value;
  const country = (document.getElementById('filter-country') as HTMLSelectElement).value;

  if (standard) params.set('standard_type', standard);
  if (vintage) { params.set('vintage_min', vintage); params.set('vintage_max', vintage); }
  if (projectType) params.set('project_type', projectType);
  if (country) params.set('country_code', country);

  try {
    const res = await fetch(`${API_BASE}/api/v1/carbon-credits?${params}`, { headers: authHeaders() });
    if (!res.ok) throw new Error(res.statusText);
    const credits: any[] = await res.json();

    if (credits.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="text-center py-8 text-slate-400 text-sm">No credits found for selected filters.</td></tr>';
      countEl.textContent = '0 credits';
      return;
    }

    countEl.textContent = `${credits.length} credits (page ${currentPage})`;

    tbody.innerHTML = credits.map(cc => `
      <tr class="hover:bg-emerald-50/50 transition-colors">
        <td class="font-medium text-slate-800 text-sm max-w-xs truncate">
          <div class="font-medium">${cc.name || 'N/A'}</div>
          <div class="text-xs text-slate-400 font-normal">${cc.project_type || ''} · ${cc.methodology || 'Standard methodology'}</div>
        </td>
        <td class="text-center">
          <span class="ccec-badge ccec-badge-blue text-xs">${cc.standard_type || 'N/A'}</span>
        </td>
        <td class="text-center font-semibold text-slate-700 text-sm">${cc.vintage || '—'}</td>
        <td class="text-right font-medium text-slate-700 text-sm">${cc.verified_ERt ? cc.verified_ERt.toLocaleString() + ' tCO₂' : '—'}</td>
        <td class="text-right font-semibold text-emerald-700 text-sm">${cc.unit_price ? cc.unit_price.toFixed(2) + ' ' + (cc.currency || 'USD') : '—'}</td>
        <td class="text-center">
          <span class="ccec-badge ${cc.is_retired ? 'ccec-badge-red' : 'ccec-badge-green'} text-xs">
            ${cc.is_retired ? 'Retired' : 'Active'}
          </span>
        </td>
        <td class="text-sm text-slate-600">${cc.country_name || cc.country_code || '—'}</td>
      </tr>
    `).join('');

    updatePagination(credits.length);
  } catch (e) {
    // Show sample data when API not available
    tbody.innerHTML = renderSampleCredits();
    countEl.textContent = 'Sample data (API offline)';
  }
}

function renderSampleCredits() {
  const samples = [
    { name: 'Bac Lieu Wind Farm', standard: 'VER', vintage: 2023, ert: 425000, price: 12.50, status: false, country: 'Vietnam' },
    { name: 'Mekong Delta Mangrove Restoration', standard: 'GOLD', vintage: 2022, ert: 185000, price: 14.20, status: false, country: 'Vietnam' },
    { name: 'Da Mi Hydropower', standard: 'VER', vintage: 2021, ert: 320000, price: 11.80, status: true, country: 'Vietnam' },
    { name: 'Central Highlands Coffee Forest', standard: 'VER', vintage: 2024, ert: 95000, price: 15.30, status: false, country: 'Vietnam' },
    { name: 'Amazon REDD+ Project', standard: 'VER', vintage: 2023, ert: 1200000, price: 16.40, status: false, country: 'Brazil' },
    { name: 'Rajasthan Solar Project', standard: 'CER', vintage: 2022, ert: 890000, price: 8.90, status: false, country: 'India' },
  ];
  return samples.map(cc => `
    <tr class="hover:bg-emerald-50/50 transition-colors">
      <td class="font-medium text-slate-800 text-sm"><div>${cc.name}</div><div class="text-xs text-slate-400 font-normal">Forestation · ACM-001</div></td>
      <td class="text-center"><span class="ccec-badge ccec-badge-blue text-xs">${cc.standard}</span></td>
      <td class="text-center font-semibold text-slate-700 text-sm">${cc.vintage}</td>
      <td class="text-right font-medium text-slate-700 text-sm">${cc.ert.toLocaleString()} tCO₂</td>
      <td class="text-right font-semibold text-emerald-700 text-sm">$${cc.price.toFixed(2)} USD</td>
      <td class="text-center"><span class="ccec-badge ${cc.status ? 'ccec-badge-red' : 'ccec-badge-green'} text-xs">${cc.status ? 'Retired' : 'Active'}</span></td>
      <td class="text-sm text-slate-600">${cc.country}</td>
    </tr>
  `).join('');
}

function updatePagination(fetchedCount: number) {
  const info = document.getElementById('pagination-info')!;
  const controls = document.getElementById('pagination-controls')!;
  info.textContent = 'Page ' + currentPage + ' - Showing ' + fetchedCount + ' results';
  controls.innerHTML =
    '<button onclick="window._ccPage=' + (currentPage - 1) + '; window._loadCredits()" class="px-3 py-1 text-xs border border-slate-200 rounded-lg hover:border-emerald-400' + (currentPage === 1 ? ' opacity-50 cursor-not-allowed' : '') + '" ' + (currentPage === 1 ? 'disabled' : '') + '>Prev</button>' +
    '<button onclick="window._ccPage=' + (currentPage + 1) + '; window._loadCredits()" class="px-3 py-1 text-xs border border-slate-200 rounded-lg hover:border-emerald-400" ' + (fetchedCount < pageSize ? 'disabled' : '') + '>Next</button>';
}

declare global { interface Window { _ccPage: number; _loadCredits: () => void; } }
window._ccPage = 1;
window._loadCredits = loadCredits;

loadCredits();

// Filter listeners
['filter-standard', 'filter-vintage', 'filter-project-type', 'filter-country'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', () => {
    currentPage = 1;
    loadCredits();
  });
});

document.getElementById('reset-filters')?.addEventListener('click', () => {
  (['filter-standard', 'filter-vintage', 'filter-project-type', 'filter-country'] as const).forEach(id => {
    (document.getElementById(id) as HTMLSelectElement).value = '';
  });
  currentPage = 1;
  loadCredits();
});
</script>