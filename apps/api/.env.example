# App
APP_NAME=CCEC Climate Platform
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ccec
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ccec

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=CHANGE_ME_USE_strong_random_secret_key_32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI — MiniMax OpenAI-compatible (Anthropic/MiniMax)
# For local dev: set your key here. For production: set MINIMAX_API_KEY in GitHub Secrets / Fly.io secrets.
MINIMAX_API_KEY=sk-cp-YOUR_MINIMAX_KEY_HERE
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# Mapbox
MAPBOX_ACCESS_TOKEN=
