# App
APP_NAME=CCEC Climate Platform
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ccec
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/ccec

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=CHANGE_ME_USE_strong_random_secret_key_32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI — Groq (primary)
OPENAI_API_KEY=your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# AI — DeepSeek (fallback)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# AI — PortKey (Claude via PortKey)
PORTKEY_API_KEY=
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# AI provider selection: groq | deepseek | portkey
AI_PROVIDER=groq

# Mapbox
MAPBOX_ACCESS_TOKEN=
