app = "ccec-web"
primary_region = "hkg"

kill_signal = "SIGINT"
kill_timeout = "5s"

[build]
  dockerfile = "infra/docker/Dockerfile.web"

[deploy]
  release_command = ""

[run]
  concurrency = "100"
  auto_rollback = "true"

[[services]]
  internal_port = 4321
  protocol = "tcp"

  [services.concurrency]
    hard_limit = 100
    soft_limit = 80

  [[services.ports]]
    port = 443
    force_https = true

  [[services.ports]]
    port = 80

  [[services.checks]]
    port = 4321
    interval = "10s"
    timeout = "2s"
    grace_period = "5s"
    restart_limit = 3