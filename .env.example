# ============================================================
# CCEC Climate Platform — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- App ---
APP_NAME="CCEC Climate Platform"
APP_VERSION="0.1.0"
DEBUG=false

# --- Server ---
HOST="0.0.0.0"
PORT=8000

# --- Database ---
# async driver (preferred)
DATABASE_URL="postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/ccec"
# sync driver (for migrations / alembic)
DATABASE_URL_SYNC="postgresql+psycopg2://postgres:CHANGE_ME@localhost:5432/ccec"

# --- Redis ---
REDIS_URL="redis://localhost:6379/0"

# --- JWT (REQUIRED — use a strong random key in production) ---
JWT_SECRET_KEY="CHANGE_ME_USE_32_PLUS_RANDOM_CHARS"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI — OpenAI-compatible (Groq primary, DeepSeek fallback, Claude via PortKey) ---
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.groq.com/openai/v1"
OPENAI_MODEL="llama-3.3-70b-versatile"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

PORTKEY_API_KEY=""
PORTKEY_BASE_URL="https://api.portkey.ai/v1"

# Which provider to use: "groq" | "deepseek" | "portkey"
AI_PROVIDER="groq"

# --- Mapbox ---
MAPBOX_ACCESS_TOKEN=""

# --- CORS (comma-separated origins, no spaces) ---
CORS_ORIGINS="http://localhost:3000,http://localhost:4321"

# --- Cloudflare SSL ---
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_EMAIL="your@email.com"